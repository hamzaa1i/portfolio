---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 — Hamza Ali">
  <Header />

  <main
    class="min-h-screen flex items-center justify-center px-6"
    style="padding-top: calc(var(--header-height) + var(--header-margin) * 2);"
  >
    <div class="text-center max-w-lg">
      <div class="glass p-4 rounded-lg mb-10 text-left w-full max-w-xs mx-auto">
        <div class="flex items-center gap-1.5 mb-3">
          <span class="w-2 h-2 rounded-full bg-[#FF5F57]"></span>
          <span class="w-2 h-2 rounded-full bg-[#FEBC2E]"></span>
          <span class="w-2 h-2 rounded-full bg-[#28C840]"></span>
        </div>
        <p class="font-mono text-xs text-text-muted">
          <span class="text-accent-primary">$</span> cd /this-page
        </p>
        <p class="font-mono text-xs text-[#EF4444] mt-1">
          bash: No such file or directory
        </p>
      </div>

      <h1
        class="text-[clamp(7rem,25vw,14rem)] font-heading font-bold text-gradient leading-none mb-6 select-none"
        data-scramble="load"
        data-404-glitch
      >
        404
      </h1>

      <p class="text-heading-3 font-heading text-text-primary mb-2">page not found</p>
      <p class="text-body text-text-secondary mb-10">
        this page doesn't exist. or maybe it never did.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" data-magnetic class="btn-primary">
          <span>go home</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </a>
        <button data-magnetic class="btn-secondary" id="btn-terminal-404">
          <span>open terminal</span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>
        </button>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  document.getElementById('btn-terminal-404')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('terminal:toggle'));
  });
</script>

<style>
  [data-404-glitch] { position: relative; cursor: default; }
  [data-404-glitch]:hover { animation: glitch404 0.3s ease; }
  @keyframes glitch404 {
    0%, 100% { transform: translate(0); }
    20% { transform: translate(-3px, 2px); }
    40% { transform: translate(3px, -2px); }
    60% { transform: translate(-2px, -1px); }
    80% { transform: translate(2px, 1px); }
  }
</style>