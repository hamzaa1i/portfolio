---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TypeWriter from '../components/TypeWriter.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import SkillOrb from '../components/SkillOrb.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ContactForm from '../components/ContactForm.tsx';

/* ── Data ── */

const roles = [
  'Digital Solutions Architect',
  'UI/UX Enthusiast',
  'AI-Powered Developer',
  'ERP Systems Engineer',
  'Brand Designer',
];

const stats = [
  { value: 3,   suffix: '+', label: 'Projects Delivered' },
  { value: 300, suffix: 'K+', label: 'Garments Tracked' },
  { value: 95,  suffix: '',   label: 'WPM Typing Speed' },
  { value: 17,  suffix: '',   label: 'Years Old' },
];

const projects = [
  {
    title: 'Reve Stitching — Corporate Website',
    description: 'Premium B2B manufacturing website with scroll animations, AI chat, quote system, admin dashboard, and dark mode.',
    type: 'Production Website',
    role: 'Sole Developer & Designer',
    stack: ['Astro 5', 'Tailwind', 'GSAP', 'Supabase', 'Vercel'],
    liveUrl: 'https://revestitching.com',
    githubUrl: 'https://github.com/hamzaa1i/reve-stitching',
    placeholderClass: 'project-placeholder-1',
  },
  {
    title: 'Factory ERP System',
    description: 'Digitized store operations — 50+ daily paper gatepasses to real-time digital tracking. Fabric stock, issuance, and automated reporting.',
    type: 'Enterprise ERP',
    role: 'ERP Implementation Lead',
    stack: ['ERPNext', 'Python', 'PostgreSQL', 'Custom Scripts'],
    liveUrl: undefined,
    githubUrl: undefined,
    placeholderClass: 'project-placeholder-2',
  },
  {
    title: 'Brand Identity Design',
    description: 'Complete brand identity for an international garment exporter — logo system, color palette, typography, business cards, and brand guidelines.',
    type: 'Brand Identity',
    role: 'Brand Designer',
    stack: ['AI-Assisted Design', 'Brand Strategy', 'Visual Identity'],
    liveUrl: 'https://revestitching.com',
    githubUrl: undefined,
    placeholderClass: 'project-placeholder-3',
  },
];

/* ── Skills with desktop positions ── */

interface SkillItem {
  name: string;
  icon: string;
  cat: string;
  top: string;
  left: string;
  float: string;
  learning?: boolean;
}

const allSkills: SkillItem[] = [
  /* Build */
  { name: 'Astro',        icon: '🚀', cat: 'Build',    top: '4%',  left: '3%',  float: 'animate-float' },
  { name: 'React',        icon: '⚛️', cat: 'Build',    top: '1%',  left: '22%', float: 'animate-float-delayed' },
  { name: 'Tailwind CSS', icon: '🎨', cat: 'Build',    top: '6%',  left: '46%', float: 'animate-float-slow' },
  { name: 'JavaScript',   icon: '⚡', cat: 'Build',    top: '2%',  left: '70%', float: 'animate-float-reverse' },
  { name: 'HTML / CSS',   icon: '🌐', cat: 'Build',    top: '9%',  left: '88%', float: 'animate-float' },

  /* Animate */
  { name: 'GSAP',          icon: '✨', cat: 'Animate',  top: '22%', left: '2%',  float: 'animate-float-delayed' },
  { name: 'Three.js',      icon: '🎲', cat: 'Animate',  top: '19%', left: '24%', float: 'animate-float-reverse' },
  { name: 'Lenis',         icon: '🧈', cat: 'Animate',  top: '25%', left: '48%', float: 'animate-float' },
  { name: 'ScrollTrigger', icon: '📜', cat: 'Animate',  top: '18%', left: '73%', float: 'animate-float-slow' },

  /* Backend */
  { name: 'ERPNext',    icon: '🏭', cat: 'Backend',  top: '40%', left: '6%',  float: 'animate-float-slow' },
  { name: 'Python',     icon: '🐍', cat: 'Backend',  top: '43%', left: '28%', float: 'animate-float' },
  { name: 'Supabase',   icon: '💚', cat: 'Backend',  top: '38%', left: '54%', float: 'animate-float-delayed' },
  { name: 'PostgreSQL', icon: '🐘', cat: 'Backend',  top: '44%', left: '78%', float: 'animate-float-reverse' },

  /* Design */
  { name: 'Brand Identity', icon: '💎', cat: 'Design', top: '59%', left: '4%',  float: 'animate-float-reverse' },
  { name: 'UI / UX',        icon: '🎯', cat: 'Design', top: '63%', left: '32%', float: 'animate-float', learning: true },
  { name: 'Figma',          icon: '🖌️', cat: 'Design', top: '57%', left: '58%', float: 'animate-float-delayed', learning: true },

  /* Tools */
  { name: 'Git & GitHub',   icon: '🔀', cat: 'Tools',  top: '77%', left: '3%',  float: 'animate-float' },
  { name: 'Vercel',         icon: '▲',  cat: 'Tools',  top: '80%', left: '26%', float: 'animate-float-slow' },
  { name: 'VS Code',        icon: '💻', cat: 'Tools',  top: '75%', left: '50%', float: 'animate-float-delayed' },
  { name: 'AI (Claude/GPT)',icon: '🤖', cat: 'Tools',  top: '82%', left: '74%', float: 'animate-float-reverse' },
];

const categories = ['Build', 'Animate', 'Backend', 'Design', 'Tools'];
---

<Layout>
  <!-- WebGL Background (desktop only) -->

  <!-- Floating Header -->
  <Header />

   <!-- ================================================================
       SECTION 1 — HERO (with cursor reveal effect)
       ================================================================ -->
  <section
    id="hero"
    data-section
    class="section-snap relative"
    style="padding-top: calc(var(--header-height) + var(--header-margin) * 2 + 2rem);"
  >

    <!-- ── Interactive dot grid ── -->
    <div class="hero-grid" aria-hidden="true"></div>

    <!-- ── Blueprint wireframe (mirrors actual portfolio layout) ── -->
    <div class="hero-blueprint" aria-hidden="true">
      <svg viewBox="0 0 1200 700" fill="none" preserveAspectRatio="xMidYMid meet">

        <!-- Group 1: Header pill — draws first -->
        <g class="bp-row" style="--bp-delay: 0">
          <rect x="300" y="15" width="600" height="34" rx="17" stroke="white" stroke-opacity="0.07" stroke-width="0.75"/>
          <rect x="330" y="26" width="60" height="12" rx="3" fill="white" fill-opacity="0.035"/>
          <rect x="700" y="24" width="55" height="18" rx="9" stroke="white" stroke-opacity="0.05" stroke-width="0.5"/>
        </g>

        <!-- Group 2: Hero left column -->
        <g class="bp-row" style="--bp-delay: 1">
          <rect x="100" y="95" width="500" height="290" rx="14" stroke="white" stroke-opacity="0.04" stroke-width="0.5" stroke-dasharray="4 4"/>
          <rect x="135" y="125" width="130" height="22" rx="11" stroke="white" stroke-opacity="0.06" stroke-width="0.5"/>
          <circle cx="150" cy="136" r="3" fill="white" fill-opacity="0.06"/>
          <rect x="135" y="172" width="280" height="16" rx="3" fill="white" fill-opacity="0.04"/>
          <rect x="135" y="198" width="190" height="11" rx="2" fill="white" fill-opacity="0.025"/>
          <rect x="135" y="232" width="400" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="135" y="246" width="340" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="135" y="285" width="120" height="34" rx="8" fill="white" fill-opacity="0.035"/>
          <rect x="270" y="285" width="120" height="34" rx="8" stroke="white" stroke-opacity="0.05" stroke-width="0.5"/>
        </g>

        <!-- Group 3: Snapshot card -->
        <g class="bp-row" style="--bp-delay: 2">
          <rect x="640" y="95" width="300" height="290" rx="14" stroke="white" stroke-opacity="0.06" stroke-width="0.75"/>
          <circle cx="670" cy="130" r="4" fill="white" fill-opacity="0.05"/>
          <rect x="684" y="125" width="75" height="10" rx="2" fill="white" fill-opacity="0.035"/>
          <rect x="670" y="158" width="240" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="670" y="172" width="200" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <line x1="670" y1="205" x2="910" y2="205" stroke="white" stroke-opacity="0.04" stroke-width="0.5"/>
          <rect x="685" y="228" width="50" height="18" rx="3" fill="white" fill-opacity="0.03"/>
          <rect x="685" y="252" width="40" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="770" y="228" width="50" height="18" rx="3" fill="white" fill-opacity="0.03"/>
          <rect x="770" y="252" width="40" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="855" y="228" width="50" height="18" rx="3" fill="white" fill-opacity="0.03"/>
          <rect x="855" y="252" width="40" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <line x1="755" y1="220" x2="755" y2="265" stroke="white" stroke-opacity="0.03" stroke-width="0.5"/>
          <line x1="840" y1="220" x2="840" y2="265" stroke="white" stroke-opacity="0.03" stroke-width="0.5"/>
        </g>

        <!-- Group 4: Project cards -->
        <g class="bp-row" style="--bp-delay: 3">
          <rect x="100" y="430" width="310" height="200" rx="14" stroke="white" stroke-opacity="0.05" stroke-width="0.75"/>
          <rect x="120" y="450" width="270" height="75" rx="8" fill="white" fill-opacity="0.018"/>
          <rect x="120" y="540" width="150" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="120" y="554" width="110" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="120" y="585" width="42" height="14" rx="4" stroke="white" stroke-opacity="0.04" stroke-width="0.5"/>
          <rect x="170" y="585" width="42" height="14" rx="4" stroke="white" stroke-opacity="0.04" stroke-width="0.5"/>

          <rect x="445" y="430" width="310" height="200" rx="14" stroke="white" stroke-opacity="0.05" stroke-width="0.75"/>
          <rect x="465" y="450" width="270" height="75" rx="8" fill="white" fill-opacity="0.018"/>
          <rect x="465" y="540" width="150" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="465" y="554" width="110" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="465" y="585" width="42" height="14" rx="4" stroke="white" stroke-opacity="0.04" stroke-width="0.5"/>
          <rect x="515" y="585" width="42" height="14" rx="4" stroke="white" stroke-opacity="0.04" stroke-width="0.5"/>
        </g>

        <!-- Group 5: CTA card + footer -->
        <g class="bp-row" style="--bp-delay: 4">
          <rect x="790" y="430" width="310" height="200" rx="14" stroke="white" stroke-opacity="0.05" stroke-width="0.75"/>
          <line x1="945" y1="480" x2="945" y2="510" stroke="white" stroke-opacity="0.06" stroke-width="1"/>
          <line x1="930" y1="495" x2="960" y2="495" stroke="white" stroke-opacity="0.06" stroke-width="1"/>
          <rect x="870" y="575" width="120" height="28" rx="8" fill="white" fill-opacity="0.03"/>

          <rect x="350" y="670" width="500" height="22" rx="11" stroke="white" stroke-opacity="0.05" stroke-width="0.5"/>
          <circle cx="560" cy="681" r="3" fill="white" fill-opacity="0.04"/>
          <circle cx="575" cy="681" r="3" fill="white" fill-opacity="0.04"/>
          <circle cx="590" cy="681" r="3" fill="white" fill-opacity="0.04"/>
        </g>

      </svg>
    </div>

    <div class="relative z-10 section-inner">
      <div class="flex flex-col lg:flex-row items-center lg:items-center gap-10 lg:gap-14">
        <!-- Left column — main content -->
        <div class="flex-1 text-center lg:text-left flex flex-col items-center lg:items-start max-w-2xl">
          <!-- Availability tag -->
          <div data-animate="fade-up" class="mb-6 sm:mb-8">
            <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass text-[0.7rem] font-mono tracking-wider text-text-secondary">
              <span class="w-1.5 h-1.5 rounded-full bg-accent-success animate-glow-pulse"></span>
              Available for projects
            </span>
          </div>

          <!-- Name -->
          <h1
            data-hover-letters
            data-scramble="load"
            class="text-display font-heading font-bold text-text-primary mb-4 sm:mb-6"
          >
            Hamza Ali
          </h1>

          <!-- Typewriter -->
          <div data-animate="fade-up" class="mb-6 sm:mb-8">
            <TypeWriter roles={roles} textClass="text-heading-3 sm:text-heading-2" />
          </div>

          <!-- Tagline -->
          <p data-animate="fade-up" class="text-body-lg text-text-secondary max-w-xl mb-10 sm:mb-12 leading-relaxed">
            I architect digital solutions and leverage AI to build systems that businesses depend on.
          </p>

          <!-- CTAs -->
          <div data-animate="fade-up" class="flex flex-col sm:flex-row items-center gap-4">
            <a href="#work" data-nav-link data-magnetic class="btn-primary">
              <span>explore my work</span>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
            <a href="#contact" data-nav-link data-magnetic class="btn-secondary">
              <span>get in touch</span>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </div>
        </div>

        <!-- Right column — Snapshot card -->
        <div data-animate="fade-up" class="w-full max-w-sm lg:w-80 xl:w-96 flex-shrink-0">
          <div class="glass p-5 sm:p-6" data-draggable>
            <div class="flex items-center gap-2 mb-3">
              <span class="w-1.5 h-1.5 rounded-full bg-accent-primary"></span>
              <span class="font-mono text-[0.7rem] font-medium text-accent-primary tracking-wider uppercase">Snapshot</span>
            </div>
            <p class="text-body-sm text-text-secondary leading-relaxed mb-5">
              Building production systems that businesses depend on — websites, ERP tooling, and brand identity — solo, powered by AI.
            </p>
            <div class="grid grid-cols-3 gap-4 border-t border-white/5 pt-4">
              <div class="text-center">
                <div class="font-heading text-xl sm:text-2xl font-bold text-accent-primary leading-none">1<span class="text-base">+</span></div>
                <div class="font-mono text-[0.6rem] text-text-dim tracking-wider uppercase mt-1.5">years building</div>
              </div>
              <div class="text-center border-x border-white/5">
                <div class="font-heading text-xl sm:text-2xl font-bold text-accent-primary leading-none">3<span class="text-base">+</span></div>
                <div class="font-mono text-[0.6rem] text-text-dim tracking-wider uppercase mt-1.5">projects shipped</div>
              </div>
              <div class="text-center">
                <div class="font-heading text-xl sm:text-2xl font-bold text-accent-primary leading-none">300<span class="text-base">K+</span></div>
                <div class="font-mono text-[0.6rem] text-text-dim tracking-wider uppercase mt-1.5">garments tracked</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-6 sm:bottom-10 left-1/2 -translate-x-1/2">
      <ScrollIndicator />
    </div>
  </section>

  <!-- ================================================================
       SECTION 2 — THE STORY
       ================================================================ -->
  <section
    id="story"
    data-section
    class="section-snap relative"
  >

    <div class="relative z-10 section-inner">
      <div class="flex items-stretch gap-8 lg:gap-14">
        <!-- Vertical text (desktop) -->
        <div class="hidden lg:flex items-center justify-center flex-shrink-0" style="width: 70px;">
          <span class="vertical-text">The Story</span>
        </div>

        <!-- Content column -->
        <div class="flex-1 max-w-2xl">
          <!-- Mobile heading -->
          <div class="lg:hidden mb-6">
            <span data-scramble class="section-label mb-2 block">About</span>
            <h2 data-split class="text-heading-1 font-heading font-bold text-text-primary">The Story</h2>
          </div>

          <!-- Paragraphs -->
          <div class="space-y-5">
            <p data-story-line class="text-body text-text-secondary leading-relaxed">
              At 17, I walked into a garment factory in Faisalabad and saw a business exporting
              <span class="text-text-primary font-medium">300,000 garments monthly</span>
              to Boohoo, Pull&Bear, and Yours Clothing — running entirely on paper and Excel.
            </p>

            <p data-story-line class="text-body text-text-secondary leading-relaxed">
              I had zero coding experience. But I had a hypothesis:
              <span class="text-gradient font-medium">AI could be the bridge</span>
              between my ideas and their execution. So I volunteered to digitize everything.
            </p>

            <p data-story-line class="text-body text-text-secondary leading-relaxed">
              I built their website from scratch — premium scroll animations, real-time quote systems, AI chat. Implemented an ERP that replaced
              <span class="text-text-primary font-medium">50 daily paper gatepasses</span>
              with digital tracking. Designed their entire brand identity.
            </p>

            <p data-story-line class="text-body text-text-secondary leading-relaxed">
              A software house quoted
              <span class="text-accent-primary font-semibold">₨2 million</span>.
              I delivered it alone, at 17, using AI as my execution engine.
            </p>

            <!-- Quote -->
            <blockquote data-story-line class="glass p-4 sm:p-5 mt-2" style="border-left: 2px solid var(--accent); border-radius: 0 0.75rem 0.75rem 0;">
              <p class="text-sm text-text-primary italic leading-relaxed font-body">
                "The thinking behind giving correct prompts to AI was me. I don't just use tools — I architect solutions."
              </p>
            </blockquote>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-8 sm:mt-10" data-animate="stagger">
            {stats.map((s) => (
              <div class="stat-card glass">
                <div class="stat-number">
                  <span data-counter={s.value.toString()} data-counter-suffix={s.suffix}>0{s.suffix}</span>
                </div>
                <div class="stat-label">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       SECTION 3 — THE ARSENAL  (Skills)
       Desktop: scattered floating orbs with proximity tilt
       Mobile:  categorised grid
       ================================================================ -->
  <section
    id="skills"
    data-section
    class="section-snap relative"
  >

    <div class="relative z-10 section-inner">
      <!-- Header -->
      <div class="text-center mb-6 lg:mb-4">
        <span data-scramble class="section-label mb-2 block">Technologies</span>
        <h2 data-split class="text-heading-1 font-heading font-bold text-text-primary mb-3">The Arsenal</h2>
        <p data-animate="fade-up" class="text-body-sm text-text-secondary max-w-sm mx-auto">
          Technologies I use to build solutions that businesses depend on.
        </p>
      </div>

      <!-- ─── Desktop: Scattered floating orbs ─── -->
      <div class="hidden lg:block relative w-full" style="height: clamp(380px, 55vh, 620px);">
        {allSkills.map((skill) => (
          <div
            class="absolute"
            style={`top: ${skill.top}; left: ${skill.left};`}
          >
            <SkillOrb
              name={skill.name}
              icon={skill.icon}
              category={skill.cat as any}
              learning={skill.learning || false}
              floatClass={skill.float}
            />
          </div>
        ))}

        <!-- Category hints — faint labels behind orbs -->
        <span class="absolute font-mono text-[0.6rem] tracking-[0.2em] uppercase text-text-dim/30 select-none pointer-events-none" style="top: 0%; left: 0%;">build</span>
        <span class="absolute font-mono text-[0.6rem] tracking-[0.2em] uppercase text-text-dim/30 select-none pointer-events-none" style="top: 17%; left: 0%;">animate</span>
        <span class="absolute font-mono text-[0.6rem] tracking-[0.2em] uppercase text-text-dim/30 select-none pointer-events-none" style="top: 36%; left: 0%;">backend</span>
        <span class="absolute font-mono text-[0.6rem] tracking-[0.2em] uppercase text-text-dim/30 select-none pointer-events-none" style="top: 55%; left: 0%;">design</span>
        <span class="absolute font-mono text-[0.6rem] tracking-[0.2em] uppercase text-text-dim/30 select-none pointer-events-none" style="top: 73%; left: 0%;">tools</span>
      </div>

      <!-- ─── Mobile: Categorised grid ─── -->
      <div class="lg:hidden space-y-6 mt-4">
        {categories.map((cat) => (
          <div>
            <h3 class="font-mono text-[0.65rem] tracking-[0.15em] uppercase text-text-dim mb-3 pl-0.5">
              {cat}
            </h3>
            <div class="flex flex-wrap gap-2" data-animate="stagger">
              {allSkills
                .filter((s) => s.cat === cat)
                .map((skill) => (
                  <SkillOrb
                    name={skill.name}
                    icon={skill.icon}
                    category={cat as any}
                    learning={skill.learning || false}
                    floatClass=""
                  />
                ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================================================================
       SECTION 4 — SELECTED WORKS
       ================================================================ -->
  <section
    id="work"
    data-section
    class="section-snap relative"
  >

    <div class="relative z-10 section-inner">
      <!-- Header -->
      <div class="mb-6 lg:mb-8">
        <span data-scramble class="section-label mb-2 block">Portfolio</span>
        <h2 data-split class="text-heading-1 font-heading font-bold text-text-primary mb-3">Selected Works</h2>
        <p data-animate="fade-up" class="text-body-sm text-text-secondary max-w-md">
          Real projects. Real businesses. Real impact. Each delivered solo, powered by AI.
        </p>
      </div>

      <!-- 2×2 Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-5">
        {projects.map((p) => (
          <ProjectCard
            title={p.title}
            description={p.description}
            type={p.type}
            role={p.role}
            stack={p.stack}
            liveUrl={p.liveUrl}
            githubUrl={p.githubUrl}
            placeholderClass={p.placeholderClass}
          />
        ))}

        <!-- CTA card -->
        <div class="project-card-interactive glass flex flex-col items-center justify-center p-6 text-center" data-animate="fade-up" style="min-height: 260px;">
          <div class="w-12 h-12 rounded-xl glass-strong flex items-center justify-center mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent-primary">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
          </div>
          <h3 class="font-heading text-sm font-semibold text-text-primary mb-1.5">Your Project?</h3>
          <p class="text-xs text-text-secondary mb-4 leading-relaxed max-w-[200px]">
            Have an idea that needs to become real? Let's build it.
          </p>
          <a href="#contact" data-nav-link data-magnetic class="btn-primary btn-sm" onclick="event.stopPropagation()">
            <span>start a conversation</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>
