---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TypeWriter from '../components/TypeWriter.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import SkillOrb from '../components/SkillOrb.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ContactForm from '../components/ContactForm.tsx';
import CurrentlyWidget from '../components/CurrentlyWidget.astro';
import SectionSkeleton from '../components/SectionSkeleton.astro';

/* ── SVG Icon Helper (Lucide-style monoline, 16×16) ── */
const i = (d: string) =>
  `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${d}</svg>`;

const icons = {
  rocket: i('<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>'),
  atom: `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="12" rx="10" ry="4"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(120 12 12)"/><circle cx="12" cy="12" r="1.5" fill="currentColor" stroke="none"/></svg>`,
  wind: i('<path d="M17.7 7.7a2.5 2.5 0 0 1 1.8 4.3H2"/><path d="M9.6 4.6A2 2 0 0 1 11 8H2"/><path d="M12.6 19.4A2 2 0 1 0 14 16H2"/>'),
  braces: i('<path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5a2 2 0 0 0 2 2h1"/><path d="M16 21h1a2 2 0 0 0 2-2v-5a2 2 0 0 1 2-2 2 2 0 0 1-2-2V5a2 2 0 0 0-2-2h-1"/>'),
  code: i('<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>'),
  sparkles: i('<path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3L12 3z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/>'),
  box: i('<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>'),
  mouse: i('<rect x="7" y="2" width="10" height="20" rx="5"/><line x1="12" y1="6" x2="12" y2="10"/>'),
  bookmark: i('<path d="m19 21-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>'),
  factory: i('<path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/>'),
  terminal: i('<polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/>'),
  zap: i('<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>'),
  database: i('<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/>'),
  gem: i('<path d="M6 3h12l4 6-10 13L2 9z"/><path d="M11 3 8 9l4 13 4-13-3-6"/><path d="M2 9h20"/>'),
  layout: i('<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/>'),
  figma: i('<path d="M5 5.5A3.5 3.5 0 0 1 8.5 2H12v7H8.5A3.5 3.5 0 0 1 5 5.5z"/><path d="M12 2h3.5a3.5 3.5 0 1 1 0 7H12z"/><path d="M12 12.5a3.5 3.5 0 1 1 7 0 3.5 3.5 0 1 1-7 0z"/><path d="M5 19.5A3.5 3.5 0 0 1 8.5 16H12v3.5a3.5 3.5 0 1 1-7 0z"/><path d="M5 12.5A3.5 3.5 0 0 1 8.5 9H12v7H8.5A3.5 3.5 0 0 1 5 12.5z"/>'),
  gitBranch: i('<line x1="6" x2="6" y1="3" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>'),
  triangle: i('<path d="M12 2 2 22h20z"/>'),
  fileCode: i('<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/><polyline points="14 2 14 8 20 8"/><path d="m10 13-2 2 2 2"/><path d="m14 17 2-2-2-2"/>'),
  cpu: i('<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/>'),
};

/* ── Data ── */

const roles = [
  'Web Developer',
  'ERP Specialist',
  'Brand Designer',
  'Full-Stack Builder',
  'Problem Solver',
];

const stats = [
  { value: 3,  suffix: '+',  label: 'Projects Shipped' },
  { value: 3,  suffix: '+',  label: 'Years Experience' },
  { value: 5,  suffix: '/5', label: 'Client Rating' },
  { value: 17, suffix: '',   label: 'Years Old' },
];

const projects = [
  {
    title: 'Reve Stitching',
    description: 'Full production website for a UK garment exporter. Custom animations, quote system, admin dashboard, and dark mode.',
    type: 'Production Website',
    role: 'Sole Developer & Designer',
    stack: ['Astro 5', 'Tailwind', 'GSAP', 'Supabase', 'Vercel'],
    liveUrl: 'https://revestitching.com',
    githubUrl: 'https://github.com/hamzaa1i/reve-stitching',
    placeholderClass: 'project-placeholder-1',
  },
  {
    title: 'Factory ERP System',
    description: 'Enterprise resource planning system for a manufacturing business. Inventory management, workflow automation, and real-time reporting.',
    type: 'Enterprise ERP',
    role: 'ERP Implementation Lead',
    stack: ['ERPNext', 'Python', 'PostgreSQL', 'Custom Scripts'],
    liveUrl: undefined,
    githubUrl: undefined,
    placeholderClass: 'project-placeholder-2',
  },
  {
    title: 'Brand Identity Design',
    description: 'Complete visual identity for an international exporter. Logo system, color palette, typography, company profile, business cards, letterheads, trim cards, and brand guidelines.',
    type: 'Brand Identity',
    role: 'Brand Designer',
    stack: ['Figma', 'Brand Strategy', 'Visual Identity'],
    liveUrl: undefined,
    githubUrl: undefined,
    placeholderClass: 'project-placeholder-3',
  },
];

/* ── Skills with professional SVG icons ── */

interface SkillItem {
  name: string;
  icon: string;
  cat: string;
  top: string;
  left: string;
  float: string;
  learning?: boolean;
}

const allSkills: SkillItem[] = [
  { name: 'Astro',        icon: icons.rocket,    cat: 'Build',    top: '4%',  left: '3%',  float: 'animate-float' },
  { name: 'React',        icon: icons.atom,      cat: 'Build',    top: '1%',  left: '22%', float: 'animate-float-delayed' },
  { name: 'Tailwind CSS', icon: icons.wind,      cat: 'Build',    top: '6%',  left: '46%', float: 'animate-float-slow' },
  { name: 'JavaScript',   icon: icons.braces,    cat: 'Build',    top: '2%',  left: '70%', float: 'animate-float-reverse' },
  { name: 'HTML / CSS',   icon: icons.code,      cat: 'Build',    top: '9%',  left: '88%', float: 'animate-float' },

  { name: 'GSAP',          icon: icons.sparkles,  cat: 'Animate',  top: '22%', left: '5%',  float: 'animate-float-delayed' },
  { name: 'Lenis',         icon: icons.mouse,     cat: 'Animate',  top: '20%', left: '38%', float: 'animate-float' },
  { name: 'ScrollTrigger', icon: icons.bookmark,  cat: 'Animate',  top: '22%', left: '72%', float: 'animate-float-slow' },

  { name: 'ERPNext',    icon: icons.factory,   cat: 'Backend',  top: '40%', left: '6%',  float: 'animate-float-slow' },
  { name: 'Python',     icon: icons.terminal,  cat: 'Backend',  top: '43%', left: '28%', float: 'animate-float' },
  { name: 'Supabase',   icon: icons.zap,       cat: 'Backend',  top: '38%', left: '54%', float: 'animate-float-delayed' },
  { name: 'PostgreSQL', icon: icons.database,  cat: 'Backend',  top: '44%', left: '78%', float: 'animate-float-reverse' },

  { name: 'Brand Identity', icon: icons.gem,     cat: 'Design', top: '59%', left: '4%',  float: 'animate-float-reverse' },
  { name: 'UI / UX',        icon: icons.layout,  cat: 'Design', top: '63%', left: '32%', float: 'animate-float', learning: true },
  { name: 'Figma',          icon: icons.figma,   cat: 'Design', top: '57%', left: '58%', float: 'animate-float-delayed', learning: true },

  { name: 'Git & GitHub',   icon: icons.gitBranch, cat: 'Tools', top: '77%', left: '3%',  float: 'animate-float' },
  { name: 'Vercel',         icon: icons.triangle,  cat: 'Tools', top: '80%', left: '26%', float: 'animate-float-slow' },
  { name: 'VS Code',        icon: icons.fileCode,  cat: 'Tools', top: '75%', left: '50%', float: 'animate-float-delayed' },
  { name: 'Claude / GPT',   icon: icons.cpu,       cat: 'Tools', top: '82%', left: '74%', float: 'animate-float-reverse' },
];

const categories = ['Build', 'Animate', 'Backend', 'Design', 'Tools'];
---

<Layout>
  <Header />

  <!-- ================================================================
       SECTION 1 — HERO
       ================================================================ -->
  <section
    id="hero"
    data-section
    class="section-snap relative"
    style="padding-top: calc(var(--header-height) + var(--header-margin) * 2 + 2rem);"
  >

    <div class="hero-grid" aria-hidden="true"></div>

    <div class="hero-blueprint" aria-hidden="true">
      <svg viewBox="0 0 1200 700" fill="none" preserveAspectRatio="xMidYMid meet">
        <g class="bp-row" style="--bp-delay: 0">
          <rect x="300" y="15" width="600" height="34" rx="17" stroke="white" stroke-opacity="0.07" stroke-width="0.75"/>
          <rect x="330" y="26" width="60" height="12" rx="3" fill="white" fill-opacity="0.035"/>
          <rect x="700" y="24" width="55" height="18" rx="9" stroke="white" stroke-opacity="0.05" stroke-width="0.5"/>
        </g>
        <g class="bp-row" style="--bp-delay: 1">
          <rect x="100" y="95" width="500" height="290" rx="14" stroke="white" stroke-opacity="0.04" stroke-width="0.5" stroke-dasharray="4 4"/>
          <rect x="135" y="125" width="130" height="22" rx="11" stroke="white" stroke-opacity="0.06" stroke-width="0.5"/>
          <circle cx="150" cy="136" r="3" fill="white" fill-opacity="0.06"/>
          <rect x="135" y="172" width="280" height="16" rx="3" fill="white" fill-opacity="0.04"/>
          <rect x="135" y="198" width="190" height="11" rx="2" fill="white" fill-opacity="0.025"/>
          <rect x="135" y="232" width="400" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="135" y="246" width="340" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="135" y="285" width="120" height="34" rx="8" fill="white" fill-opacity="0.035"/>
          <rect x="270" y="285" width="120" height="34" rx="8" stroke="white" stroke-opacity="0.05" stroke-width="0.5"/>
        </g>
        <g class="bp-row" style="--bp-delay: 2">
          <rect x="640" y="95" width="300" height="290" rx="14" stroke="white" stroke-opacity="0.06" stroke-width="0.75"/>
          <circle cx="670" cy="130" r="4" fill="white" fill-opacity="0.05"/>
          <rect x="684" y="125" width="75" height="10" rx="2" fill="white" fill-opacity="0.035"/>
          <rect x="670" y="158" width="240" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="670" y="172" width="200" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <line x1="670" y1="205" x2="910" y2="205" stroke="white" stroke-opacity="0.04" stroke-width="0.5"/>
          <rect x="685" y="228" width="50" height="18" rx="3" fill="white" fill-opacity="0.03"/>
          <rect x="685" y="252" width="40" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="770" y="228" width="50" height="18" rx="3" fill="white" fill-opacity="0.03"/>
          <rect x="770" y="252" width="40" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="855" y="228" width="50" height="18" rx="3" fill="white" fill-opacity="0.03"/>
          <rect x="855" y="252" width="40" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <line x1="755" y1="220" x2="755" y2="265" stroke="white" stroke-opacity="0.03" stroke-width="0.5"/>
          <line x1="840" y1="220" x2="840" y2="265" stroke="white" stroke-opacity="0.03" stroke-width="0.5"/>
        </g>
        <g class="bp-row" style="--bp-delay: 3">
          <rect x="100" y="430" width="310" height="200" rx="14" stroke="white" stroke-opacity="0.05" stroke-width="0.75"/>
          <rect x="120" y="450" width="270" height="75" rx="8" fill="white" fill-opacity="0.018"/>
          <rect x="120" y="540" width="150" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="120" y="554" width="110" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="120" y="585" width="42" height="14" rx="4" stroke="white" stroke-opacity="0.04" stroke-width="0.5"/>
          <rect x="170" y="585" width="42" height="14" rx="4" stroke="white" stroke-opacity="0.04" stroke-width="0.5"/>
          <rect x="445" y="430" width="310" height="200" rx="14" stroke="white" stroke-opacity="0.05" stroke-width="0.75"/>
          <rect x="465" y="450" width="270" height="75" rx="8" fill="white" fill-opacity="0.018"/>
          <rect x="465" y="540" width="150" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="465" y="554" width="110" height="5" rx="2" fill="white" fill-opacity="0.02"/>
          <rect x="465" y="585" width="42" height="14" rx="4" stroke="white" stroke-opacity="0.04" stroke-width="0.5"/>
          <rect x="515" y="585" width="42" height="14" rx="4" stroke="white" stroke-opacity="0.04" stroke-width="0.5"/>
        </g>
        <g class="bp-row" style="--bp-delay: 4">
          <rect x="790" y="430" width="310" height="200" rx="14" stroke="white" stroke-opacity="0.05" stroke-width="0.75"/>
          <line x1="945" y1="480" x2="945" y2="510" stroke="white" stroke-opacity="0.06" stroke-width="1"/>
          <line x1="930" y1="495" x2="960" y2="495" stroke="white" stroke-opacity="0.06" stroke-width="1"/>
          <rect x="870" y="575" width="120" height="28" rx="8" fill="white" fill-opacity="0.03"/>
          <rect x="350" y="670" width="500" height="22" rx="11" stroke="white" stroke-opacity="0.05" stroke-width="0.5"/>
          <circle cx="560" cy="681" r="3" fill="white" fill-opacity="0.04"/>
          <circle cx="575" cy="681" r="3" fill="white" fill-opacity="0.04"/>
          <circle cx="590" cy="681" r="3" fill="white" fill-opacity="0.04"/>
        </g>
      </svg>
    </div>

    <div class="relative z-10 section-inner skel-wrap" data-skel="hero">
      <!-- Skeleton placeholder -->
      <SectionSkeleton type="hero" />

      <!-- Real content (starts invisible, fades in when loaded) -->
      <div class="skel-real">
        <div class="flex flex-col lg:flex-row items-center lg:items-center gap-10 lg:gap-14">
          <div class="flex-1 text-center lg:text-left flex flex-col items-center lg:items-start max-w-2xl">
            <div data-animate="fade-up" class="mb-6 sm:mb-8">
<span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass text-[0.7rem] font-mono tracking-wider text-text-secondary">
  <span class="w-1.5 h-1.5 rounded-full bg-accent-success animate-glow-pulse"></span>
  <span id="hero-greeting">Available for projects</span>
</span>
            </div>

            <h1
              data-hover-letters
              data-scramble="load"
              class="text-display font-heading font-bold text-text-primary mb-4 sm:mb-6"
            >
              Hamza Ali
            </h1>

            <div data-animate="fade-up" class="mb-6 sm:mb-8">
              <TypeWriter roles={roles} textClass="text-heading-3 sm:text-heading-2" />
            </div>

            <p data-animate="fade-up" class="text-body-lg text-text-secondary max-w-xl mb-10 sm:mb-12 leading-relaxed">
              I build websites, enterprise systems, and brands for businesses that need to ship.
            </p>

            <div data-animate="fade-up" class="flex flex-col sm:flex-row items-center gap-4">
              <a href="#work" data-nav-link data-magnetic class="btn-primary">
                <span>explore my work</span>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </a>
              <a href="#contact" data-nav-link data-magnetic class="btn-secondary">
                <span>get in touch</span>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
              </a>
            </div>
          </div>

          <div data-animate="fade-up" class="w-full max-w-sm lg:w-80 xl:w-96 flex-shrink-0">
            <div class="glass p-5 sm:p-6" data-draggable>
              <div class="flex items-center gap-2 mb-3">
                <span class="w-1.5 h-1.5 rounded-full bg-accent-primary"></span>
                <span class="font-mono text-[0.7rem] font-medium text-accent-primary tracking-wider uppercase">Snapshot</span>
              </div>
              <p class="text-body-sm text-text-secondary leading-relaxed mb-5">
                Full-stack developer building production systems for real clients. Websites, ERP, branding.
              </p>
              <div class="grid grid-cols-3 gap-4 border-t border-white/5 pt-4">
                <div class="text-center">
                  <div class="font-heading text-xl sm:text-2xl font-bold text-accent-primary leading-none">3<span class="text-base">+</span></div>
                  <div class="font-mono text-[0.6rem] text-text-muted tracking-wider uppercase mt-1.5">years exp</div>
                </div>
                <div class="text-center border-x border-white/5">
                  <div class="font-heading text-xl sm:text-2xl font-bold text-accent-primary leading-none">3<span class="text-base">+</span></div>
                  <div class="font-mono text-[0.6rem] text-text-muted tracking-wider uppercase mt-1.5">projects</div>
                </div>
                <div class="text-center">
                  <div class="font-heading text-xl sm:text-2xl font-bold text-accent-primary leading-none">5<span class="text-base">/5</span></div>
                  <div class="font-mono text-[0.6rem] text-text-muted tracking-wider uppercase mt-1.5">rating</div>
                </div>
              </div>
            </div>
              <CurrentlyWidget />
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-6 sm:bottom-10 left-1/2 -translate-x-1/2">
      <ScrollIndicator />
    </div>
  </section>

  <!-- ================================================================
       SECTION 2 — THE STORY
       ================================================================ -->
  <section
    id="story"
    data-section
    class="section-snap relative"
  >
    <div class="relative z-10 section-inner skel-wrap" data-skel="story">
      <!-- Skeleton placeholder -->
      <SectionSkeleton type="story" />

      <!-- Real content (starts invisible, fades in when loaded) -->
      <div class="skel-real">
        <div class="flex items-stretch gap-8 lg:gap-14">
          <div class="hidden lg:flex items-center justify-center flex-shrink-0" style="width: 70px;">
            <span class="vertical-text">The Story</span>
          </div>

          <div class="flex-1 max-w-2xl">
            <div class="lg:hidden mb-6">
              <span data-scramble class="section-label mb-2 block">About</span>
              <h2 data-split data-parallax="0.8" class="text-heading-1 font-heading font-bold text-text-primary">The Story</h2>
            </div>

            <div class="space-y-5">
              <p data-story-line class="text-body text-text-secondary leading-relaxed">
                I started building things on the internet when I was
                <span class="text-text-primary font-medium">14</span>.
                Small projects, broken code, a lot of learning by doing. Three years later, I'm
                <span class="text-gradient font-medium">shipping production code</span>
                for real businesses.
              </p>

              <p data-story-line class="text-body text-text-secondary leading-relaxed">
                My biggest project so far has been for a garment exporter that ships to the UK. They needed a website, an ERP system, and a complete rebrand. I built
                <span class="text-text-primary font-medium">all of it on my own</span>.
              </p>

              <p data-story-line class="text-body text-text-secondary leading-relaxed">
                The website has custom scroll animations, a quote calculator, and an admin panel. The ERP handles their inventory and workflow. The branding covers everything from the logo to letterheads.
              </p>

              <p data-story-line class="text-body text-text-secondary leading-relaxed">
                I work fast, communicate clearly, and
                <span class="text-gradient font-medium">actually finish what I start</span>.
                If you need something built right, I'm here.
              </p>

              <blockquote data-story-line class="glass p-4 sm:p-5 mt-2" style="border-left: 2px solid var(--accent); border-radius: 0 0.75rem 0.75rem 0;">
                <p class="text-sm text-text-primary italic leading-relaxed font-body">
                  "Give me a problem and I'll find a way to solve it. That's basically what I do."
                </p>
              </blockquote>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-8 sm:mt-10" data-animate="stagger">
              {stats.map((s) => (
                <div class="stat-card glass">
                  <div class="stat-number">
                    <span data-counter={s.value.toString()} data-counter-suffix={s.suffix}>0{s.suffix}</span>
                  </div>
                  <div class="stat-label">{s.label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================================================================
       SECTION 3 — THE ARSENAL
       ================================================================ -->
  <section
    id="skills"
    data-section
    class="section-snap relative"
  >
