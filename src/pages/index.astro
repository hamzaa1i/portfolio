---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import InteractiveBackground from '../components/InteractiveBackground.tsx';
import TypeWriter from '../components/TypeWriter.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import SkillOrb from '../components/SkillOrb.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ContactForm from '../components/ContactForm.tsx';

/* ── Data ── */

const roles = [
  'Digital Solutions Architect',
  'UI/UX Enthusiast',
  'AI-Powered Developer',
  'ERP Systems Engineer',
  'Brand Designer',
];

const stats = [
  { value: 3,   suffix: '+', label: 'Projects Delivered' },
  { value: 300, suffix: 'K+', label: 'Garments Tracked' },
  { value: 95,  suffix: '',   label: 'WPM Typing Speed' },
  { value: 17,  suffix: '',   label: 'Years Old' },
];

const projects = [
  {
    title: 'Reve Stitching — Corporate Website',
    description: 'Premium B2B manufacturing website with scroll animations, AI chat, quote system, admin dashboard, and dark mode.',
    type: 'Production Website',
    role: 'Sole Developer & Designer',
    stack: ['Astro 5', 'Tailwind', 'GSAP', 'Supabase', 'Vercel'],
    liveUrl: 'https://revestitching.com',
    githubUrl: 'https://github.com/hamzaa1i/reve-stitching',
    placeholderClass: 'project-placeholder-1',
  },
  {
    title: 'Factory ERP System',
    description: 'Digitized store operations — 50+ daily paper gatepasses to real-time digital tracking. Fabric stock, issuance, and automated reporting.',
    type: 'Enterprise ERP',
    role: 'ERP Implementation Lead',
    stack: ['ERPNext', 'Python', 'PostgreSQL', 'Custom Scripts'],
    liveUrl: undefined,
    githubUrl: undefined,
    placeholderClass: 'project-placeholder-2',
  },
  {
    title: 'Brand Identity Design',
    description: 'Complete brand identity for an international garment exporter — logo system, color palette, typography, business cards, and brand guidelines.',
    type: 'Brand Identity',
    role: 'Brand Designer',
    stack: ['AI-Assisted Design', 'Brand Strategy', 'Visual Identity'],
    liveUrl: 'https://revestitching.com',
    githubUrl: undefined,
    placeholderClass: 'project-placeholder-3',
  },
];

/* ── Skills with desktop positions ── */

interface SkillItem {
  name: string;
  icon: string;
  cat: string;
  top: string;
  left: string;
  float: string;
  learning?: boolean;
}

const allSkills: SkillItem[] = [
  /* Build */
  { name: 'Astro',        icon: '🚀', cat: 'Build',    top: '4%',  left: '3%',  float: 'animate-float' },
  { name: 'React',        icon: '⚛️', cat: 'Build',    top: '1%',  left: '22%', float: 'animate-float-delayed' },
  { name: 'Tailwind CSS', icon: '🎨', cat: 'Build',    top: '6%',  left: '46%', float: 'animate-float-slow' },
  { name: 'JavaScript',   icon: '⚡', cat: 'Build',    top: '2%',  left: '70%', float: 'animate-float-reverse' },
  { name: 'HTML / CSS',   icon: '🌐', cat: 'Build',    top: '9%',  left: '88%', float: 'animate-float' },

  /* Animate */
  { name: 'GSAP',          icon: '✨', cat: 'Animate',  top: '22%', left: '2%',  float: 'animate-float-delayed' },
  { name: 'Three.js',      icon: '🎲', cat: 'Animate',  top: '19%', left: '24%', float: 'animate-float-reverse' },
  { name: 'Lenis',         icon: '🧈', cat: 'Animate',  top: '25%', left: '48%', float: 'animate-float' },
  { name: 'ScrollTrigger', icon: '📜', cat: 'Animate',  top: '18%', left: '73%', float: 'animate-float-slow' },

  /* Backend */
  { name: 'ERPNext',    icon: '🏭', cat: 'Backend',  top: '40%', left: '6%',  float: 'animate-float-slow' },
  { name: 'Python',     icon: '🐍', cat: 'Backend',  top: '43%', left: '28%', float: 'animate-float' },
  { name: 'Supabase',   icon: '💚', cat: 'Backend',  top: '38%', left: '54%', float: 'animate-float-delayed' },
  { name: 'PostgreSQL', icon: '🐘', cat: 'Backend',  top: '44%', left: '78%', float: 'animate-float-reverse' },

  /* Design */
  { name: 'Brand Identity', icon: '💎', cat: 'Design', top: '59%', left: '4%',  float: 'animate-float-reverse' },
  { name: 'UI / UX',        icon: '🎯', cat: 'Design', top: '63%', left: '32%', float: 'animate-float', learning: true },
  { name: 'Figma',          icon: '🖌️', cat: 'Design', top: '57%', left: '58%', float: 'animate-float-delayed', learning: true },

  /* Tools */
  { name: 'Git & GitHub',   icon: '🔀', cat: 'Tools',  top: '77%', left: '3%',  float: 'animate-float' },
  { name: 'Vercel',         icon: '▲',  cat: 'Tools',  top: '80%', left: '26%', float: 'animate-float-slow' },
  { name: 'VS Code',        icon: '💻', cat: 'Tools',  top: '75%', left: '50%', float: 'animate-float-delayed' },
  { name: 'AI (Claude/GPT)',icon: '🤖', cat: 'Tools',  top: '82%', left: '74%', float: 'animate-float-reverse' },
];

const categories = ['Build', 'Animate', 'Backend', 'Design', 'Tools'];
---

<Layout>
  <!-- WebGL Background (desktop only) -->
  <InteractiveBackground client:load />

  <!-- Floating Header -->
  <Header />

   <!-- ================================================================
       SECTION 1 — HERO (with cursor reveal effect)
       ================================================================ -->
  <section
    id="hero"
    data-section
    class="section-snap relative"
    style="padding-top: calc(var(--header-height) + var(--header-margin) * 2 + 2rem);"
  >
    <!-- Ambient glow — animated, z-index below reveal -->
    <div class="absolute inset-0 pointer-events-none" style="z-index: 2;" aria-hidden="true">
      <div class="ambient-orb hero-orb-1" style="width: clamp(320px, 45vw, 600px); height: clamp(320px, 45vw, 600px); top: 5%; left: 5%;"></div>
      <div class="ambient-orb hero-orb-2" style="width: clamp(260px, 35vw, 480px); height: clamp(260px, 35vw, 480px); bottom: 12%; right: 6%;"></div>
      <div class="ambient-orb hero-orb-3" style="width: clamp(180px, 25vw, 350px); height: clamp(180px, 25vw, 350px); top: 55%; left: 50%;"></div>
    </div>

    <!-- ── REVEAL LAYER — dense code matrix ── -->
    <div class="hero-reveal-layer" aria-hidden="true">

      <!-- ═══════ CODE BLOCK 1 — top-left: Hamza config ═══════ -->
      <span style="top:4%; left:3%; opacity:0.5; font-size:0.72rem; color:var(--accent);">const developer = {</span>
      <span style="top:7%; left:5%; opacity:0.35; font-size:0.65rem;">  name: 'Hamza Ali',</span>
      <span style="top:10%; left:5%; opacity:0.35; font-size:0.65rem;">  age: 17,</span>
      <span style="top:13%; left:5%; opacity:0.35; font-size:0.65rem;">  location: 'Faisalabad, PK',</span>
      <span style="top:16%; left:5%; opacity:0.4; font-size:0.65rem;">  role: 'Digital Solutions Architect',</span>
      <span style="top:19%; left:5%; opacity:0.3; font-size:0.65rem;">  ai: true,</span>
      <span style="top:22%; left:5%; opacity:0.35; font-size:0.65rem;">  coffee: Infinity,</span>
      <span style="top:25%; left:3%; opacity:0.5; font-size:0.72rem; color:var(--accent);">};</span>

      <!-- ═══════ CODE BLOCK 2 — top-right: build function ═══════ -->
      <span style="top:3%; right:5%; opacity:0.3; font-size:0.6rem; color:var(--text-dim);">// what I do every day</span>
      <span style="top:6%; right:5%; opacity:0.5; font-size:0.7rem; color:var(--accent);">async function build(idea) {'{'}</span>
      <span style="top:9%; right:3%; opacity:0.35; font-size:0.65rem;">  const stack = await selectStack(idea);</span>
      <span style="top:12%; right:3%; opacity:0.35; font-size:0.65rem;">  const design = await craftUI(idea);</span>
      <span style="top:15%; right:3%; opacity:0.35; font-size:0.65rem;">  const system = await architect(stack, design);</span>
      <span style="top:18%; right:3%; opacity:0.4; font-size:0.65rem; color:var(--accent);">  return deploy(system);</span>
      <span style="top:21%; right:5%; opacity:0.5; font-size:0.7rem; color:var(--accent);">{'}'}</span>

      <!-- ═══════ CODE BLOCK 3 — mid-left: skills array ═══════ -->
      <span style="top:34%; left:2%; opacity:0.45; font-size:0.68rem; color:var(--accent);">const skills = [</span>
      <span style="top:37%; left:4%; opacity:0.3; font-size:0.62rem;">  'Astro',    'React',     'Tailwind',</span>
      <span style="top:40%; left:4%; opacity:0.3; font-size:0.62rem;">  'GSAP',     'Three.js',  'Lenis',</span>
      <span style="top:43%; left:4%; opacity:0.3; font-size:0.62rem;">  'Python',   'ERPNext',   'Supabase',</span>
      <span style="top:46%; left:4%; opacity:0.3; font-size:0.62rem;">  'Figma',    'Git',       'Vercel',</span>
      <span style="top:49%; left:2%; opacity:0.45; font-size:0.68rem; color:var(--accent);">];</span>

      <!-- ═══════ CODE BLOCK 4 — mid-right: factory class ═══════ -->
      <span style="top:30%; right:4%; opacity:0.3; font-size:0.58rem; color:var(--text-dim);">// real impact, real numbers</span>
      <span style="top:33%; right:4%; opacity:0.5; font-size:0.7rem; color:var(--accent);">class Factory {'{'}</span>
      <span style="top:36%; right:2%; opacity:0.35; font-size:0.63rem;">  garments = 300_000;  // per month</span>
      <span style="top:39%; right:2%; opacity:0.35; font-size:0.63rem;">  clients = ['Boohoo', 'Pull&Bear'];</span>
      <span style="top:42%; right:2%; opacity:0.35; font-size:0.63rem;">  gatepasses = 50;     // daily, digitized</span>
      <span style="top:45%; right:2%; opacity:0.3; font-size:0.63rem;">  softwareQuote = '₨2,000,000';</span>
      <span style="top:48%; right:2%; opacity:0.45; font-size:0.63rem; color:var(--accent);">  hamzaCost = '₨0';   // delivered solo</span>
      <span style="top:51%; right:4%; opacity:0.5; font-size:0.7rem; color:var(--accent);">{'}'}</span>

      <!-- ═══════ CODE BLOCK 5 — bottom-left: deploy pipeline ═══════ -->
      <span style="bottom:30%; left:2%; opacity:0.3; font-size:0.58rem; color:var(--text-dim);">// ship it</span>
      <span style="bottom:27%; left:2%; opacity:0.45; font-size:0.68rem; color:var(--accent);">const pipeline = [</span>
      <span style="bottom:24%; left:4%; opacity:0.3; font-size:0.62rem;">  'design()',</span>
      <span style="bottom:21%; left:4%; opacity:0.3; font-size:0.62rem;">  'develop()',</span>
      <span style="bottom:18%; left:4%; opacity:0.3; font-size:0.62rem;">  'test()',</span>
      <span style="bottom:15%; left:4%; opacity:0.35; font-size:0.62rem;">  'deploy()',</span>
      <span style="bottom:12%; left:4%; opacity:0.4; font-size:0.62rem; color:var(--accent);">  'iterate()',</span>
      <span style="bottom:9%; left:2%; opacity:0.45; font-size:0.68rem; color:var(--accent);">];</span>

      <!-- ═══════ CODE BLOCK 6 — bottom-right: export ═══════ -->
      <span style="bottom:28%; right:3%; opacity:0.3; font-size:0.58rem; color:var(--text-dim);">// ready for your project</span>
      <span style="bottom:25%; right:3%; opacity:0.5; font-size:0.7rem; color:var(--accent);">export default {'{'}</span>
      <span style="bottom:22%; right:1%; opacity:0.35; font-size:0.63rem;">  available: true,</span>
      <span style="bottom:19%; right:1%; opacity:0.35; font-size:0.63rem;">  response: '24-48h',</span>
      <span style="bottom:16%; right:1%; opacity:0.35; font-size:0.63rem;">  stack: 'modern',</span>
      <span style="bottom:13%; right:1%; opacity:0.4; font-size:0.63rem; color:var(--accent);">  approach: 'AI-powered',</span>
      <span style="bottom:10%; right:3%; opacity:0.5; font-size:0.7rem; color:var(--accent);">{'}'}</span>

      <!-- ═══════ FLOATING KEYWORDS — scattered across center ═══════ -->
      <span style="top:28%; left:38%; opacity:0.15; font-size:1.1rem; color:var(--accent); transform:rotate(-12deg);">async</span>
      <span style="top:55%; left:42%; opacity:0.12; font-size:1rem; color:var(--text-dim); transform:rotate(8deg);">await</span>
      <span style="top:62%; left:25%; opacity:0.14; font-size:0.95rem; color:var(--accent); transform:rotate(-5deg);">deploy</span>
      <span style="top:20%; left:45%; opacity:0.1; font-size:1.2rem; color:var(--text-dim); transform:rotate(15deg);">import</span>
      <span style="top:72%; left:55%; opacity:0.12; font-size:1rem; color:var(--accent); transform:rotate(-8deg);">export</span>
      <span style="top:38%; left:60%; opacity:0.1; font-size:1.1rem; color:var(--text-dim); transform:rotate(10deg);">return</span>
      <span style="top:80%; left:35%; opacity:0.13; font-size:0.9rem; color:var(--accent); transform:rotate(-3deg);">render</span>
      <span style="top:15%; left:58%; opacity:0.11; font-size:1rem; color:var(--text-dim); transform:rotate(6deg);">const</span>
      <span style="top:68%; left:70%; opacity:0.12; font-size:0.95rem; color:var(--accent); transform:rotate(-10deg);">function</span>
      <span style="top:45%; left:30%; opacity:0.1; font-size:1.15rem; color:var(--text-dim); transform:rotate(4deg);">class</span>

      <!-- ═══════ SYMBOLS — brackets, arrows, operators ═══════ -->
      <span style="top:5%; left:35%; opacity:0.2; font-size:1.8rem; color:var(--accent); transform:rotate(5deg);">{'{'}</span>
      <span style="top:5%; left:40%; opacity:0.2; font-size:1.8rem; color:var(--accent); transform:rotate(-5deg);">{'}'}</span>
      <span style="top:85%; left:60%; opacity:0.18; font-size:1.8rem; color:var(--accent); transform:rotate(8deg);">{'<'}/{'>'}</span>
      <span style="top:50%; left:15%; opacity:0.15; font-size:1.5rem; color:var(--text-dim); transform:rotate(-15deg);">=&gt;</span>
      <span style="top:75%; left:80%; opacity:0.15; font-size:1.5rem; color:var(--accent); transform:rotate(12deg);">===</span>
      <span style="top:10%; left:75%; opacity:0.12; font-size:1.6rem; color:var(--text-dim); transform:rotate(-8deg);">&&</span>
      <span style="top:60%; left:85%; opacity:0.14; font-size:1.4rem; color:var(--accent); transform:rotate(6deg);">||</span>
      <span style="top:32%; left:82%; opacity:0.1; font-size:1.5rem; color:var(--text-dim); transform:rotate(-10deg);">...</span>
      <span style="top:88%; left:15%; opacity:0.16; font-size:1.3rem; color:var(--accent); transform:rotate(3deg);">::</span>
      <span style="top:42%; left:92%; opacity:0.12; font-size:1.4rem; color:var(--text-dim); transform:rotate(-6deg);">?.</span>
      <span style="top:90%; left:45%; opacity:0.15; font-size:1.6rem; color:var(--accent); transform:rotate(10deg);">#</span>
      <span style="top:2%; left:55%; opacity:0.13; font-size:1.5rem; color:var(--text-dim); transform:rotate(-12deg);">@</span>

      <!-- ═══════ DOT GRID — subtle pattern layer ═══════ -->
      <span style="top:8%; left:48%; opacity:0.08; font-size:0.5rem; letter-spacing:1.2em; color:var(--text-dim);">· · · · · · · · ·</span>
      <span style="top:11%; left:48%; opacity:0.06; font-size:0.5rem; letter-spacing:1.2em; color:var(--text-dim);">· · · · · · · · ·</span>
      <span style="top:14%; left:48%; opacity:0.08; font-size:0.5rem; letter-spacing:1.2em; color:var(--text-dim);">· · · · · · · · ·</span>
      <span style="top:17%; left:48%; opacity:0.06; font-size:0.5rem; letter-spacing:1.2em; color:var(--text-dim);">· · · · · · · · ·</span>

      <span style="top:55%; left:5%; opacity:0.07; font-size:0.5rem; letter-spacing:1.2em; color:var(--text-dim);">· · · · · · ·</span>
      <span style="top:58%; left:5%; opacity:0.05; font-size:0.5rem; letter-spacing:1.2em; color:var(--text-dim);">· · · · · · ·</span>
      <span style="top:61%; left:5%; opacity:0.07; font-size:0.5rem; letter-spacing:1.2em; color:var(--text-dim);">· · · · · · ·</span>

      <span style="top:70%; right:5%; opacity:0.06; font-size:0.5rem; letter-spacing:1.2em; color:var(--text-dim);">· · · · · · · ·</span>
      <span style="top:73%; right:5%; opacity:0.08; font-size:0.5rem; letter-spacing:1.2em; color:var(--text-dim);">· · · · · · · ·</span>
      <span style="top:76%; right:5%; opacity:0.06; font-size:0.5rem; letter-spacing:1.2em; color:var(--text-dim);">· · · · · · · ·</span>

      <!-- ═══════ LINE NUMBERS — left gutter feel ═══════ -->
      <span style="top:35%; left:36%; opacity:0.08; font-size:0.55rem; color:var(--text-dim); line-height:1.8;">01<br/>02<br/>03<br/>04<br/>05<br/>06<br/>07<br/>08<br/>09<br/>10<br/>11<br/>12</span>
      <span style="top:5%; left:70%; opacity:0.06; font-size:0.55rem; color:var(--text-dim); line-height:1.8;">14<br/>15<br/>16<br/>17<br/>18<br/>19<br/>20<br/>21<br/>22</span>
      <span style="bottom:5%; left:50%; opacity:0.07; font-size:0.55rem; color:var(--text-dim); line-height:1.8;">31<br/>32<br/>33<br/>34<br/>35<br/>36<br/>37</span>

      <!-- ═══════ TERMINAL PROMPTS — scattered ═══════ -->
      <span style="top:83%; left:5%; opacity:0.25; font-size:0.62rem; color:var(--accent);">~/hamza $</span>
      <span style="top:83%; left:16%; opacity:0.2; font-size:0.62rem;">npm run build</span>
      <span style="top:86%; left:5%; opacity:0.15; font-size:0.6rem; color:var(--text-muted);">✓ Built in 1.2s</span>
      <span style="top:89%; left:5%; opacity:0.25; font-size:0.62rem; color:var(--accent);">~/hamza $</span>
      <span style="top:89%; left:16%; opacity:0.2; font-size:0.62rem;">git push origin main</span>
      <span style="top:92%; left:5%; opacity:0.15; font-size:0.6rem; color:var(--text-muted);">✓ Deployed to production</span>

      <span style="top:55%; right:2%; opacity:0.2; font-size:0.6rem; color:var(--accent);">▶</span>
      <span style="top:55%; right:5%; opacity:0.18; font-size:0.6rem;">node server.js</span>
      <span style="top:58%; right:2%; opacity:0.12; font-size:0.58rem; color:var(--text-muted);">listening on :4321</span>

      <!-- ═══════ COMMENT ANNOTATIONS — scattered wisdom ═══════ -->
      <span style="top:30%; left:22%; opacity:0.15; font-size:0.58rem; color:var(--text-dim); transform:rotate(-2deg);">// TODO: change the world</span>
      <span style="top:65%; left:40%; opacity:0.12; font-size:0.56rem; color:var(--text-dim); transform:rotate(3deg);">/* built with AI, architected by me */</span>
      <span style="top:78%; left:58%; opacity:0.14; font-size:0.58rem; color:var(--text-dim); transform:rotate(-4deg);">// no shortcuts, just solutions</span>
      <span style="top:48%; left:48%; opacity:0.1; font-size:0.55rem; color:var(--text-dim); transform:rotate(2deg);">/** @author hamza — age 17 */</span>
      <span style="top:25%; left:65%; opacity:0.13; font-size:0.57rem; color:var(--text-dim); transform:rotate(-6deg);">// from paper to digital</span>
      <span style="top:93%; left:40%; opacity:0.12; font-size:0.56rem; color:var(--text-dim); transform:rotate(1deg);">// 300K garments. Zero bugs.</span>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto text-center flex flex-col items-center">
      <!-- Availability tag -->
      <div data-animate="fade-up" class="mb-6 sm:mb-8">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass text-[0.7rem] font-mono tracking-wider text-text-secondary">
          <span class="w-1.5 h-1.5 rounded-full bg-accent-success animate-glow-pulse"></span>
          Available for projects
        </span>
      </div>

      <!-- Name — letter hover pop -->
      <h1
        data-hover-letters
        class="text-display font-heading font-bold text-text-primary mb-4 sm:mb-6"
      >
        Hamza Ali
      </h1>

      <!-- Typewriter -->
      <div data-animate="fade-up" class="mb-6 sm:mb-8">
        <TypeWriter roles={roles} textClass="text-heading-3 sm:text-heading-2" />
      </div>

      <!-- Tagline -->
      <p data-animate="fade-up" class="text-body-lg text-text-secondary max-w-xl mx-auto mb-10 sm:mb-12 leading-relaxed">
        I architect digital solutions and leverage AI to build systems that businesses depend on.
      </p>

      <!-- CTAs -->
      <div data-animate="fade-up" class="flex flex-col sm:flex-row items-center gap-4">
        <a href="#work" data-nav-link class="btn-primary">
          <span>explore my work</span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </a>
        <a href="#contact" data-nav-link class="btn-secondary">
          <span>get in touch</span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-6 sm:bottom-10 left-1/2 -translate-x-1/2">
      <ScrollIndicator />
    </div>
  </section>

  <!-- ================================================================
       SECTION 2 — THE STORY
       ================================================================ -->
  <section
    id="story"
    data-section
    class="section-snap relative"
  >
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="ambient-orb ambient-orb-gold" style="width: clamp(220px, 30vw, 420px); height: clamp(220px, 30vw, 420px); top: 15%; right: 12%;"></div>
      <div class="ambient-orb ambient-orb-dim" style="width: clamp(180px, 25vw, 360px); height: clamp(180px, 25vw, 360px); bottom: 20%; left: 8%;"></div>
    </div>

    <div class="relative z-10 section-inner">
      <div class="flex items-stretch gap-8 lg:gap-14">
        <!-- Vertical text (desktop) -->
        <div class="hidden lg:flex items-center justify-center flex-shrink-0" style="width: 70px;">
          <span class="vertical-text">The Story</span>
        </div>

        <!-- Content column -->
        <div class="flex-1 max-w-2xl">
          <!-- Mobile heading -->
          <div class="lg:hidden mb-6">
            <span class="section-label mb-2 block">About</span>
            <h2 data-split class="text-heading-1 font-heading font-bold text-text-primary">The Story</h2>
          </div>

          <!-- Paragraphs -->
          <div class="space-y-5">
            <p data-story-line class="text-body text-text-secondary leading-relaxed">
              At 17, I walked into a garment factory in Faisalabad and saw a business exporting
              <span class="text-text-primary font-medium">300,000 garments monthly</span>
              to Boohoo, Pull&Bear, and Yours Clothing — running entirely on paper and Excel.
            </p>

            <p data-story-line class="text-body text-text-secondary leading-relaxed">
              I had zero coding experience. But I had a hypothesis:
              <span class="text-gradient font-medium">AI could be the bridge</span>
              between my ideas and their execution. So I volunteered to digitize everything.
            </p>

            <p data-story-line class="text-body text-text-secondary leading-relaxed">
              I built their website from scratch — premium scroll animations, real-time quote systems, AI chat. Implemented an ERP that replaced
              <span class="text-text-primary font-medium">50 daily paper gatepasses</span>
              with digital tracking. Designed their entire brand identity.
            </p>

            <p data-story-line class="text-body text-text-secondary leading-relaxed">
              A software house quoted
              <span class="text-accent-primary font-semibold">₨2 million</span>.
              I delivered it alone, at 17, using AI as my execution engine.
            </p>

            <!-- Quote -->
            <blockquote data-story-line class="glass p-4 sm:p-5 mt-2" style="border-left: 2px solid var(--accent); border-radius: 0 0.75rem 0.75rem 0;">
              <p class="text-sm text-text-primary italic leading-relaxed font-body">
                "The thinking behind giving correct prompts to AI was me. I don't just use tools — I architect solutions."
              </p>
            </blockquote>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-8 sm:mt-10" data-animate="stagger">
            {stats.map((s) => (
              <div class="stat-card glass">
                <div class="stat-number">
