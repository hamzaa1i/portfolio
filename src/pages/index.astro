<style>
  /* Hero needs extra top padding for floating header */
  #hero {
    padding-top: calc(var(--header-height) + var(--header-margin) * 2 + 2rem);
  }

  /* Non-hero snapping sections get gentle top padding to avoid header overlap */
  #story, #skills, #work, #contact {
    padding-top: calc(var(--header-height) + var(--header-margin) * 2 + 1.5rem);
  }

  /* ─── Contact link hover states ─── */
  .contact-link:nth-child(1):hover {
    border-color: rgba(16, 185, 129, 0.15) !important;
    background: rgba(16, 185, 129, 0.03) !important;
  }
  .contact-link:nth-child(2):hover {
    border-color: rgba(200, 162, 78, 0.15) !important;
    background: rgba(200, 162, 78, 0.03) !important;
  }
  .contact-link:nth-child(3):hover {
    border-color: rgba(250, 250, 250, 0.08) !important;
    background: rgba(250, 250, 250, 0.02) !important;
  }

  /* ─── Desktop stat sizes ─── */
  @media (max-width: 639px) {
    .stat-card { padding: 1rem 0.75rem; }
    .stat-card .stat-number { font-size: clamp(1.5rem, 6vw, 2rem); }
    .stat-card .stat-label { font-size: 0.625rem; }
  }

  /* ─── Arsenal orb container — overflow visible for float ─── */
  #skills .relative[style*="height"] {
    overflow: visible;
  }
</style>