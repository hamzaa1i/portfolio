<script>
  (function() {
    var el = document.getElementById('hero-greeting');
    if (!el) return;
    var hour = new Date().toLocaleString('en-US', {
      timeZone: 'Asia/Karachi',
      hour: 'numeric',
      hour12: false,
    });
    var h = parseInt(hour);
    var greeting = 'Available for projects';
    if (h >= 5 && h < 12) greeting = 'Good morning — available for projects';
    else if (h >= 12 && h < 17) greeting = 'Good afternoon — available for projects';
    else if (h >= 17 && h < 21) greeting = 'Good evening — available for projects';
    else greeting = 'Working late — still available';
    el.textContent = greeting;
  })();
</script>

