---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = [
  {
    slug: 'building-website-at-17',
    title: 'How I Built a Production Website at 17',
    date: 'November 2025',
    readingTime: '5 min read',
    excerpt: 'The story of how I built a full production website for a garment exporter shipping to the UK.',
    tags: ['Astro', 'GSAP', 'Supabase'],
  },
  {
    slug: 'erp-for-manufacturing',
    title: 'Implementing ERPNext for a Real Factory',
    date: 'December 2025',
    readingTime: '4 min read',
    excerpt: 'How I replaced paper-based processes with a digital ERP system for a garment factory.',
    tags: ['ERPNext', 'Python', 'PostgreSQL'],
  },
  {
    slug: 'first-brand-identity',
    title: 'Designing a Brand Identity from Scratch',
    date: 'October 2025',
    readingTime: '4 min read',
    excerpt: 'What I learned creating a complete visual identity for a garment exporter with no formal design training.',
    tags: ['Brand Design', 'Figma', 'Strategy'],
  },
];
---

<Layout title="Writing — Hamza Ali" description="Thoughts on building websites, ERP systems, and brand identities for real businesses.">
  <Header />

  <main
    class="min-h-screen px-6"
    style="padding-top: calc(var(--header-height) + var(--header-margin) * 2 + 3rem);"
  >
    <div class="max-w-2xl mx-auto">
      <div class="mb-10">
        <a href="/" class="inline-flex items-center gap-1.5 text-text-dim font-mono text-xs hover:text-accent-primary transition-colors mb-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          back to home
        </a>
        <h1 class="text-heading-1 font-heading font-bold text-text-primary mb-2">Writing</h1>
        <p class="text-body text-text-secondary">Thoughts on building, shipping, and learning along the way.</p>
      </div>

      <div class="space-y-4">
        {posts.map((post) => (
          <a href={`/writing/${post.slug}`} class="block glass p-5 sm:p-6 group hover:border-white/[0.1] transition-all duration-300">
            <div class="flex items-center gap-3 font-mono text-[0.65rem] text-text-dim mb-3">
              <time>{post.date}</time>
              <span class="text-text-dim/30">·</span>
              <span>{post.readingTime}</span>
            </div>
            <h2 class="text-lg font-heading font-semibold text-text-primary mb-2 group-hover:text-accent-primary transition-colors">
              {post.title}
            </h2>
            <p class="text-body-sm text-text-secondary leading-relaxed mb-4">{post.excerpt}</p>
            <div class="flex items-center justify-between">
              <div class="flex flex-wrap gap-1.5">
                {post.tags.map((tag) => (
                  <span class="font-mono text-[0.55rem] tracking-wider uppercase px-2 py-0.5 rounded-full border border-white/[0.06] text-text-dim">
                    {tag}
                  </span>
                ))}
              </div>
              <span class="font-mono text-xs text-accent-primary opacity-0 group-hover:opacity-100 transition-opacity">
                read →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <div class="py-10"></div>
  <Footer />
</Layout>