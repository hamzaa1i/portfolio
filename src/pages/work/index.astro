---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const projects = [
  {
    slug: 'reve-stitching',
    title: 'Reve Stitching',
    type: 'Production Website',
    year: '2025',
    description: 'Full production website for a UK garment exporter with custom animations, quote system, and admin dashboard.',
    tags: ['Astro', 'Tailwind', 'GSAP', 'Supabase'],
  },
  {
    slug: 'erp-system',
    title: 'Factory ERP System',
    type: 'Enterprise ERP',
    year: '2025',
    description: 'Enterprise resource planning system replacing 50+ daily paper processes with digital tracking.',
    tags: ['ERPNext', 'Python', 'PostgreSQL'],
  },
  {
    slug: 'brand-identity',
    title: 'Brand Identity Design',
    type: 'Brand Identity',
    year: '2024',
    description: 'Complete visual identity for an international exporter including logo, stationery, and brand guidelines.',
    tags: ['Figma', 'Brand Strategy', 'Visual Identity'],
  },
];
---

<Layout title="Work — Hamza Ali">
  <Header />

  <main class="min-h-screen px-6" style="padding-top: calc(var(--header-height) + var(--header-margin) * 2 + 3rem);">
    <div class="max-w-3xl mx-auto">
      <div class="mb-10">
        <a href="/" class="inline-flex items-center gap-1.5 text-text-dim font-mono text-xs hover:text-accent-primary transition-colors mb-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          back to home
        </a>
        <h1 class="text-heading-1 font-heading font-bold text-text-primary mb-2">Case Studies</h1>
        <p class="text-body text-text-secondary">Detailed breakdowns of real projects I shipped solo.</p>
      </div>

      <div class="space-y-4">
        {projects.map((p) => (
          <a href={`/work/${p.slug}`} class="block glass p-6 group hover:border-white/[0.1] transition-all duration-300">
            <div class="flex items-center justify-between mb-3">
              <span class="font-mono text-[0.6rem] tracking-wider uppercase text-accent-primary">{p.type}</span>
              <span class="font-mono text-[0.6rem] text-text-dim">{p.year}</span>
            </div>
            <h2 class="text-xl font-heading font-bold text-text-primary mb-2 group-hover:text-accent-primary transition-colors">{p.title}</h2>
            <p class="text-body-sm text-text-secondary leading-relaxed mb-4">{p.description}</p>
            <div class="flex items-center justify-between">
              <div class="flex flex-wrap gap-1.5">
                {p.tags.map((tag) => (
                  <span class="font-mono text-[0.55rem] tracking-wider uppercase px-2 py-0.5 rounded-full border border-white/[0.06] text-text-dim">{tag}</span>
                ))}
              </div>
              <span class="font-mono text-xs text-accent-primary opacity-0 group-hover:opacity-100 transition-opacity">view →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <div class="py-10"></div>
  <Footer />
</Layout>