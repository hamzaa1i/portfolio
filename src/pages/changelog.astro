---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const versions = [
  {
    version: 'v1.5',
    date: 'March 18, 2026',
    tag: 'latest',
    changes: [
      'Expandable music player with 20 tracks, search, and shuffle',
      'Smooth crossfade between tracks',
      'Case study pages for all 3 projects',
      'Interactive resume page',
      'Keyboard shortcuts overlay (press ?)',
      'Copy email on click with toast notification',
      'Time-based greeting in hero',
      'Reading progress bar on articles',
      'Liquid glass effect on all cards',
      'Improved page transitions',
    ],
  },
  {
    version: 'v1.4',
    date: 'March 17, 2026',
    tag: null,
    changes: [
      'Added 13 interactive easter eggs',
      'Command palette (Ctrl+K)',
      'Writing section with project deep-dives',
      'Custom 404 page',
      'PWA support',
      'Changelog page',
    ],
  },
  {
    version: 'v1.2',
    date: 'March 16, 2026',
    tag: null,
    changes: [
      'Rewrote all content for natural tone',
      'Removed AI-defensive language',
      'Cleaned up factory-specific jargon',
      'Updated experience to 3+ years',
    ],
  },
  {
    version: 'v1.1',
    date: 'March 15, 2026',
    tag: null,
    changes: [
      'Removed all WebGL for performance',
      'Single unified rAF loop',
      'Removed section snapping',
      'Removed backdrop-filter on cards',
      'Optimized for low-spec hardware',
    ],
  },
  {
    version: 'v1.0',
    date: 'March 14, 2026',
    tag: null,
    changes: [
      'Initial portfolio launch',
      'Theme system with 6 color presets',
      'Interactive terminal with 15+ commands',
      'Magnetic buttons and laser glow effects',
      'Draggable snapshot card',
      'Smooth scroll with Lenis',
      'Dynamic favicon per theme',
      'Deployed to Vercel',
    ],
  },
];
---

<Layout title="Changelog — Hamza Ali">
  <Header />

  <main
    class="min-h-screen px-6"
    style="padding-top: calc(var(--header-height) + var(--header-margin) * 2 + 3rem);"
  >
    <div class="max-w-2xl mx-auto">
      <div class="mb-10">
        <a href="/" class="inline-flex items-center gap-1.5 text-text-dim font-mono text-xs hover:text-accent-primary transition-colors mb-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          back to home
        </a>
        <h1 class="text-heading-1 font-heading font-bold text-text-primary mb-2">Changelog</h1>
        <p class="text-body text-text-secondary">What's new, what's fixed, what's changed.</p>
      </div>

      <div class="space-y-0">
        {versions.map((v, i) => (
          <div class="relative pl-8 pb-10 border-l border-white/[0.06] last:pb-0">
            <div class="absolute left-0 top-1 w-2 h-2 rounded-full -translate-x-[4.5px]"
                 style={i === 0 ? 'background: var(--accent);' : 'background: var(--text-dim);'}></div>

            <div class="flex items-center gap-3 mb-3 flex-wrap">
              <span class="font-heading text-lg font-bold text-text-primary">{v.version}</span>
              {v.tag && (
                <span class="font-mono text-[0.6rem] tracking-wider uppercase px-2 py-0.5 rounded-full"
                      style="background: var(--accent-subtle); color: var(--accent); border: 1px solid var(--accent-glow);">
                  {v.tag}
                </span>
              )}
              <span class="font-mono text-xs text-text-dim">{v.date}</span>
            </div>

            <ul class="space-y-1.5">
              {v.changes.map((change) => (
                <li class="flex items-start gap-2 text-body-sm text-text-secondary">
                  <span class="text-accent-primary mt-1.5 flex-shrink-0 text-[0.5rem]">●</span>
                  {change}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </main>

  <div class="py-10"></div>
  <Footer />
</Layout>