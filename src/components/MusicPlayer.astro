  .mp-ctrl:hover { color: var(--text-primary); background: rgba(255,255,255,0.05); }
  .mp-ctrl:active { transform: scale(0.92); }
  .mp-ctrl.active { color: var(--accent); }
  .mp-ctrl-main {
    width: 36px; height: 36px; border-radius: 50%;
