    padding: 2px 6px; border-radius: 4px;
  }

  .mp-genre-tabs {
    display: flex; gap: 0; padding: 0; border-bottom: 1px solid rgba(255,255,255,0.04);
    overflow-x: auto; flex-shrink: 0; scrollbar-width: none;
  }
  .mp-genre-tabs::-webkit-scrollbar { display: none; }
  .mp-genre-tab {
    font-family: 'JetBrains Mono', monospace; font-size: 0.55rem;
    color: var(--text-dim); padding: 0.5rem 0.75rem;
    cursor: pointer; transition: color 0.2s, background 0.2s;
    white-space: nowrap; border: none; background: none;
    border-bottom: 2px solid transparent; flex-shrink: 0;
  }
  .mp-genre-tab:hover { color: var(--text-secondary); }
  .mp-genre-tab.active {
    color: var(--accent); border-bottom-color: var(--accent);
  }

  .mp-search-wrap {
    display: flex; align-items: center; gap: 0.4rem;
    padding: 0.5rem 0.875rem; border-bottom: 1px solid rgba(255,255,255,0.04); flex-shrink: 0;
  }
  .mp-search-wrap svg { color: var(--text-dim); flex-shrink: 0; }
  .mp-search-input {
    flex: 1; background: none; border: none; outline: none;
    font-family: 'JetBrains Mono', monospace; font-size: 0.65rem;
    color: var(--text-primary); caret-color: var(--accent);
  }
  .mp-search-input::placeholder { color: var(--text-dim); }

  .mp-list-items {
    flex: 1; overflow-y: auto; padding: 0.375rem;
    scrollbar-width: thin; scrollbar-color: var(--accent-dim) transparent;
  }
  .mp-list-items::-webkit-scrollbar { width: 3px; }
  .mp-list-items::-webkit-scrollbar-thumb { background: var(--accent-dim); border-radius: 3px; }

  .mp-list-item {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.4rem 0.5rem; border-radius: 0.375rem;
    cursor: pointer; transition: background 0.2s ease;
  }
  .mp-list-item:hover { background: rgba(255,255,255,0.05); }
  .mp-list-item.active { background: rgba(255,255,255,0.06); }

  .mp-list-item-playing {
    width: 12px; height: 12px; display: none;
    align-items: flex-end; gap: 1px; flex-shrink: 0;
  }
  .mp-list-item.active .mp-list-item-playing { display: flex; }
  .mp-list-item-playing span {
    width: 2px; background: var(--accent); border-radius: 1px;
    animation: mpB 0.6s ease-in-out infinite;
  }
  .mp-list-item-playing span:nth-child(2) { animation-delay: 0.15s; }
  .mp-list-item-playing span:nth-child(3) { animation-delay: 0.3s; }

  @media (max-width: 639px) {
    .music-player { bottom: 1rem; right: 1rem; }
    .music-toggle { width: 36px; height: 36px; border-radius: 10px; }
    .music-panel { width: 240px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .music-player.playing .music-bar {
      animation-duration: 0.6s !important;
      animation-iteration-count: infinite !important;
      transition-duration: 0.3s !important;
    }
    .music-player.playing .music-bar:nth-child(1) { animation: mpB 0.6s ease-in-out infinite !important; }
    .music-player.playing .music-bar:nth-child(2) { animation: mpB 0.6s ease-in-out 0.1s infinite !important; }
    .music-player.playing .music-bar:nth-child(3) { animation: mpB 0.6s ease-in-out 0.2s infinite !important; }
    .music-player.playing .music-bar:nth-child(4) { animation: mpB 0.6s ease-in-out 0.3s infinite !important; }
    .mp-list-item-playing span {
      animation-duration: 0.6s !important;
      animation-iteration-count: infinite !important;
    }
    .music-player {
      animation: mpFadeIn 0.6s ease 2s forwards !important;
    }
  }

</style>

