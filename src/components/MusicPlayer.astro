  .mp-ctrl-main:hover { background: var(--accent-hover); color: var(--accent-contrast); transform: scale(1.05); }

  .mp-track-list { max-height: 380px; display: flex; flex-direction: column; }

  .mp-list-header {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.75rem 0.875rem; border-bottom: 1px solid rgba(255,255,255,0.06); flex-shrink: 0;
