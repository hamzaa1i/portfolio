  var genres = ['All', 'Ambient', 'Focus', 'Night', 'Calm', 'Minimal'];

  function getFreq(base, semitones) { return base * Math.pow(2, semitones / 12); }

  function getRandomTrack() {
    var pool = activeGenre === 'All' ? tracks : tracks.filter(function(t) { return t.genre === activeGenre; });
    var available = [];
    for (var i = 0; i < pool.length; i++) {
      var globalIdx = tracks.indexOf(pool[i]);
      if (playHistory.indexOf(globalIdx) === -1) available.push(globalIdx);
    }
    if (available.length === 0) {
      playHistory = [currentTrack];
      for (var j = 0; j < pool.length; j++) {
        var gi = tracks.indexOf(pool[j]);
        if (gi !== currentTrack) available.push(gi);
      }
    }
    if (available.length === 0) return (currentTrack + 1) % tracks.length;
    return available[Math.floor(Math.random() * available.length)];
  }

  function buildTrack(trackIdx) {
    if (ctx) { try { ctx.close(); } catch(e) {} ctx = null; }
    try { ctx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e) { return null; }
    var thisCtx = ctx;

    var track = tracks[trackIdx];
    var master = ctx.createGain();
    master.gain.value = 0;
    master.connect(ctx.destination);

    var padNotes = [0, 2, 3];
    padNotes.forEach(function(idx) {
      if (idx >= track.scale.length) return;
      var freq = getFreq(track.baseFreq, track.scale[idx]);
      var o1 = ctx.createOscillator(); var o2 = ctx.createOscillator();
      var g = ctx.createGain(); var f = ctx.createBiquadFilter();
      o1.type = 'sine'; o2.type = 'sine';
      o1.frequency.value = freq; o2.frequency.value = freq * 1.003;
      f.type = 'lowpass'; f.frequency.value = 800; f.Q.value = 0.5;
      g.gain.value = 0.04;
      o1.connect(f); o2.connect(f); f.connect(g); g.connect(master);
      o1.start(); o2.start();
      (function drift() {
        if (thisCtx !== ctx || !ctx || ctx.state === 'closed') return;
        var t = ctx.currentTime;
        o1.frequency.setTargetAtTime(freq + (Math.random() - 0.5) * freq * 0.003, t, 4);
        f.frequency.setTargetAtTime(500 + Math.random() * 500, t, 6);
        setTimeout(drift, 3000 + Math.random() * 4000);
      })();
    });

    (function sparkle() {
      if (thisCtx !== ctx || !ctx || ctx.state === 'closed' || ctx.state === 'suspended') return;
      var o = ctx.createOscillator(); var g = ctx.createGain();
      var si = Math.floor(Math.random() * track.scale.length);
      o.frequency.value = getFreq(track.baseFreq, track.scale[si]) * (2 + Math.floor(Math.random() * 2));
      o.type = 'sine';
      var t = ctx.currentTime;
      g.gain.setValueAtTime(0, t);
      g.gain.linearRampToValueAtTime(0.01 + Math.random() * 0.008, t + 0.4);
      g.gain.exponentialRampToValueAtTime(0.001, t + 3);
      o.connect(g); g.connect(master); o.start(t); o.stop(t + 3);
      setTimeout(sparkle, 1500 + Math.random() * 5000);
    })();

    var sub = ctx.createOscillator(); var sg = ctx.createGain(); var sf = ctx.createBiquadFilter();
    sub.type = 'sine'; sub.frequency.value = track.baseFreq / 2;
    sf.type = 'lowpass'; sf.frequency.value = 200; sg.gain.value = 0.05;
    sub.connect(sf); sf.connect(sg); sg.connect(master); sub.start();

    return master;
  }

  function updateUI() {
    var t = tracks[currentTrack];
    if (isPlaying) {
      player.classList.add('playing');
      bars.style.display = 'flex'; playIcon.style.display = 'none';
      if (btnPlay) btnPlay.style.display = 'none';
      if (btnPause) btnPause.style.display = 'block';
    } else {
      player.classList.remove('playing');
      bars.style.display = 'none'; playIcon.style.display = 'block';
      if (btnPlay) btnPlay.style.display = 'block';
      if (btnPause) btnPause.style.display = 'none';
    }
    if (trackNameEl) {
      trackNameEl.textContent = t.name;
      trackNameEl.setAttribute('style', "font-family:'JetBrains Mono',monospace;font-size:0.7rem;font-weight:600;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;");
    }
    if (trackGenreEl) {
      trackGenreEl.textContent = t.genre;
      trackGenreEl.setAttribute('style', "font-family:'JetBrains Mono',monospace;font-size:0.5rem;color:var(--accent);letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;opacity:0.8;");
    }
    if (shuffleBtn) { if (shuffleMode) shuffleBtn.classList.add('active'); else shuffleBtn.classList.remove('active'); }
    renderTrackList();
  }

  function startVis() {
    if (visInterval) clearInterval(visInterval);
    visInterval = setInterval(function() {
      visBars.forEach(function(bar) { bar.style.height = (isPlaying ? (4 + Math.random() * 28) : 4) + 'px'; });
    }, 200);
  }
  function stopVis() {
    if (visInterval) clearInterval(visInterval);
    visBars.forEach(function(bar) { bar.style.height = '4px'; });
  }

  function scheduleAutoNext() {
    clearTimeout(autoNextTimer);
    if (!isPlaying) return;
    autoNextTimer = setTimeout(function() { if (isPlaying) switchTrack(1); }, TRACK_DURATION);
  }

  function startMusic() {
    if (isPlaying) return;
    var muted = false;
    try { muted = localStorage.getItem('portfolio-muted') === '1'; } catch(e) {}
    if (muted) return;
    isPlaying = true;
    if (ctx && ctx.state === 'suspended') {
      ctx.resume();
      if (masterGain) {
        masterGain.gain.cancelScheduledValues(ctx.currentTime);
        masterGain.gain.setValueAtTime(masterGain.gain.value, ctx.currentTime);
        masterGain.gain.linearRampToValueAtTime(0.55, ctx.currentTime + 1);
      }
    } else {
      masterGain = buildTrack(currentTrack);
      if (masterGain && ctx) {
        masterGain.gain.setValueAtTime(0, ctx.currentTime);
        masterGain.gain.linearRampToValueAtTime(0.55, ctx.currentTime + 2);
      }
    }
    updateUI(); startVis(); scheduleAutoNext();
    try {
      localStorage.setItem('music-playing', '1');
      localStorage.setItem('music-track', currentTrack.toString());
      localStorage.setItem('music-ever-played', '1');
    } catch(e) {}
  }

  function stopMusic() {
    if (!isPlaying) return;
    isPlaying = false;
    clearTimeout(autoNextTimer);
    if (masterGain && ctx && ctx.state === 'running') {
      masterGain.gain.cancelScheduledValues(ctx.currentTime);
      masterGain.gain.setValueAtTime(masterGain.gain.value, ctx.currentTime);
      masterGain.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.5);
      setTimeout(function() { if (ctx && ctx.state === 'running' && !isPlaying) ctx.suspend(); }, 600);
    }
    updateUI(); stopVis();
    try { localStorage.setItem('music-playing', '0'); } catch(e) {}
  }

  function switchTrack(dir) {
    var wasPlaying = isPlaying;
    if (shuffleMode && dir === 1) {
      playHistory.push(currentTrack);
      var nextIdx = getRandomTrack();
    } else if (dir === -1 && playHistory.length > 0) {
      var nextIdx = playHistory.pop();
    } else {
      var nextIdx = (currentTrack + dir + tracks.length) % tracks.length;
    }

    if (wasPlaying && masterGain && ctx && ctx.state === 'running') {
      isPlaying = false; clearTimeout(autoNextTimer);
      masterGain.gain.cancelScheduledValues(ctx.currentTime);
      masterGain.gain.setValueAtTime(masterGain.gain.value, ctx.currentTime);
      masterGain.gain.linearRampToValueAtTime(0, ctx.currentTime + 1.5);
      var oldCtx = ctx; ctx = null; masterGain = null;
      currentTrack = nextIdx;
      try { localStorage.setItem('music-track', currentTrack.toString()); } catch(e) {}
      updateUI();
      setTimeout(function() { try { oldCtx.close(); } catch(e) {} startMusic(); }, 1600);
    } else {
      isPlaying = false; clearTimeout(autoNextTimer);
      if (ctx) { try { ctx.close(); } catch(e) {} ctx = null; }
      masterGain = null; currentTrack = nextIdx;
      try { localStorage.setItem('music-track', currentTrack.toString()); } catch(e) {}
      updateUI();
      if (wasPlaying) setTimeout(function() { startMusic(); }, 100);
    }
  }

  function playTrackByIndex(idx) {
    isPlaying = false; clearTimeout(autoNextTimer);
    if (ctx) { try { ctx.close(); } catch(e) {} ctx = null; }
    masterGain = null; playHistory.push(currentTrack);
    currentTrack = idx;
    try { localStorage.setItem('music-track', currentTrack.toString()); } catch(e) {}
    updateUI();
    setTimeout(function() { startMusic(); }, 100);
  }

  /* ── Genre Tabs ── */
  function renderGenreTabs() {
    if (!genreTabsContainer) return;
    genreTabsContainer.innerHTML = '';
    genres.forEach(function(g) {
      var btn = document.createElement('button');
      btn.className = 'mp-genre-tab' + (g === activeGenre ? ' active' : '');
      btn.textContent = g;
      btn.addEventListener('click', function() {
        activeGenre = g;
        renderGenreTabs();
        renderTrackList();
      });
      genreTabsContainer.appendChild(btn);
    });
  }

  /* ── Track List ── */
  function renderTrackList(filter) {
    if (!listItemsContainer) return;
    listItemsContainer.innerHTML = '';
    var q = (filter || '').toLowerCase();
    var filtered = [];
    tracks.forEach(function(t, i) {
      var matchesGenre = activeGenre === 'All' || t.genre === activeGenre;
      var matchesSearch = !q || t.name.toLowerCase().indexOf(q) !== -1;
      if (matchesGenre && matchesSearch) filtered.push({ track: t, index: i });
    });
    if (listCountEl) listCountEl.textContent = filtered.length.toString();
    if (filtered.length === 0) {
      listItemsContainer.innerHTML = '<div style="text-align:center;padding:1.5rem;font-family:\'JetBrains Mono\',monospace;font-size:0.65rem;color:var(--text-dim);">no tracks found</div>';
      return;
    }
    filtered.forEach(function(item) {
      var div = document.createElement('div');
      div.className = 'mp-list-item' + (item.index === currentTrack ? ' active' : '');
      var num = item.index + 1;
      var padded = num < 10 ? '0' + num : '' + num;
      var nc = item.index === currentTrack ? 'var(--accent)' : 'var(--text-dim)';
      var tc = item.index === currentTrack ? 'var(--accent)' : 'var(--text-secondary)';
      var tw = item.index === currentTrack ? '600' : '400';
      div.innerHTML =
        '<span style="font-family:\'JetBrains Mono\',monospace;font-size:0.55rem;color:' + nc + ';min-width:1.75rem;text-align:right;flex-shrink:0;display:inline-block;margin-right:0.625rem;">' + padded + '</span>' +
        '<span style="font-family:\'JetBrains Mono\',monospace;font-size:0.65rem;color:' + tc + ';font-weight:' + tw + ';flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + item.track.name + '</span>' +
        '<div class="mp-list-item-playing"><span></span><span></span><span></span></div>';
      div.addEventListener('click', function() { playTrackByIndex(item.index); showNowPlaying(); });
      listItemsContainer.appendChild(div);
    });
  }

  function showTrackList() {
    showingList = true;
    if (nowPlayingView) nowPlayingView.style.display = 'none';
    if (trackListView) trackListView.style.display = 'flex';
    if (searchInput) { searchInput.value = ''; }
    renderGenreTabs();
    renderTrackList();
  }
  function showNowPlaying() {
    showingList = false;
    if (trackListView) trackListView.style.display = 'none';
    if (nowPlayingView) nowPlayingView.style.display = 'block';
  }
  function toggleExpand() {
    isExpanded = !isExpanded;
    if (isExpanded) { player.classList.add('expanded'); showNowPlaying(); }
    else { player.classList.remove('expanded'); showNowPlaying(); }
  }

  /* ── Click Handlers ── */
  var lastClickTime = 0;
  toggle.addEventListener('click', function() {
    var now = Date.now();
    var diff = now - lastClickTime;
    lastClickTime = now;

    if (diff < 350) {
      /* Double click — toggle expand */
      toggleExpand();
    } else {
      /* Single click — delayed to check for double */
      setTimeout(function() {
        if (Date.now() - lastClickTime >= 340) {
          /* Confirmed single click — play/pause */
          if (isPlaying) stopMusic(); else startMusic();

          /* Show expand hint on first play */
          if (!hasShownExpandHint && isPlaying) {
            hasShownExpandHint = true;
            try { localStorage.setItem('music-expand-hint', '1'); } catch(e) {}
            if (window.__showToast) window.__showToast('double-click to expand player');
          }
        }
      }, 350);
    }
  });

  /* Right-click to expand player */
  toggle.addEventListener('contextmenu', function(e) {
    e.preventDefault();
    e.stopPropagation();
    toggleExpand();
    return false;
  });

  /* Also catch right-click on the player container to be safe */
  player.addEventListener('contextmenu', function(e) {
    if (e.target.closest('.music-toggle')) {
      e.preventDefault();
      e.stopPropagation();
      toggleExpand();
      return false;
    }
  });

  if (panelClose) panelClose.addEventListener('click', function() { isExpanded = false; player.classList.remove('expanded'); showNowPlaying(); });
  if (playBtn) playBtn.addEventListener('click', function() { if (isPlaying) stopMusic(); else startMusic(); });
  if (nextBtn) nextBtn.addEventListener('click', function() { switchTrack(1); });
  if (prevBtn) prevBtn.addEventListener('click', function() { switchTrack(-1); });
  if (shuffleBtn) shuffleBtn.addEventListener('click', function() { shuffleMode = !shuffleMode; updateUI(); });
  if (listToggle) listToggle.addEventListener('click', showTrackList);
  if (listBack) listBack.addEventListener('click', showNowPlaying);
  if (searchInput) searchInput.addEventListener('input', function() { renderTrackList(searchInput.value); });
    /* Genre click — opens track list filtered to current genre */
  if (trackGenreEl) {
    trackGenreEl.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();
      if (!isExpanded) return;
      activeGenre = tracks[currentTrack].genre;
      showTrackList();
    });
  }

  document.addEventListener('click', function(e) {
    if (isExpanded && document.contains(e.target) && !player.contains(e.target)) { isExpanded = false; player.classList.remove('expanded'); showNowPlaying(); }
  });

  /* ── Mute integration ── */
  document.addEventListener('sound:muted', function() {
    if (isPlaying) { try { localStorage.setItem('music-was-playing', '1'); } catch(e) {} stopMusic(); }
  });
  document.addEventListener('sound:unmuted', function() {
    try { if (localStorage.getItem('music-was-playing') === '1') startMusic(); } catch(e) {}
  });

  /* ── Init ── */
  try {
    hasShownExpandHint = localStorage.getItem('music-expand-hint') === '1';
    var savedPlaying = localStorage.getItem('music-playing');
    var savedTrack = localStorage.getItem('music-track');
    var muted = localStorage.getItem('portfolio-muted') === '1';
    var everPlayed = localStorage.getItem('music-ever-played') === '1';
    if (savedTrack !== null) currentTrack = parseInt(savedTrack) || 0;
    else currentTrack = Math.floor(Math.random() * tracks.length);
    if (savedPlaying === '1' && !muted && everPlayed) setTimeout(function() { startMusic(); }, 1200);
  } catch(e) { currentTrack = Math.floor(Math.random() * tracks.length); }

  updateUI();
})();
</script>