<style>
  .music-player {
    position: fixed; bottom: 1.25rem; right: 1.25rem; z-index: 90;
    opacity: 0; transform: translateY(10px);
    animation: mpFadeIn 0.6s ease 2s forwards;
  }
  @keyframes mpFadeIn { to { opacity: 1; transform: translateY(0); } }

  .music-toggle {
    width: 40px; height: 40px; border-radius: 12px;
    background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
    border: 1px solid rgba(255,255,255,0.07);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    display: flex; align-items: center; justify-content: center; cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.2s ease;
    color: var(--text-muted);
    box-shadow: inset 0 1px 0 0 rgba(255,255,255,0.05), 0 4px 16px rgba(0,0,0,0.2);
    position: relative; z-index: 2;
  }
  .music-toggle:hover {
    background: var(--glass-hover, rgba(255,255,255,0.05));
    border-color: var(--glass-hover-border, rgba(255,255,255,0.1));
    transform: scale(1.05); color: var(--accent);
  }

  .music-bars { display: flex; align-items: flex-end; gap: 2px; height: 14px; }
  .music-bar { width: 2.5px; background: currentColor; border-radius: 1px; height: 4px; }
  .music-player.playing .music-bar:nth-child(1) { animation: mpB 0.6s ease-in-out infinite; }
  .music-player.playing .music-bar:nth-child(2) { animation: mpB 0.6s ease-in-out 0.1s infinite; }
  .music-player.playing .music-bar:nth-child(3) { animation: mpB 0.6s ease-in-out 0.2s infinite; }
  .music-player.playing .music-bar:nth-child(4) { animation: mpB 0.6s ease-in-out 0.3s infinite; }
  @keyframes mpB { 0%,100% { height: 4px; } 50% { height: 14px; } }

  .music-panel {
    position: absolute; bottom: calc(100% + 0.5rem); right: 0;
    width: 260px;
    background: linear-gradient(135deg, rgba(9,9,11,0.96) 0%, rgba(9,9,11,0.9) 100%);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
    border-radius: 0.875rem; overflow: hidden;
    box-shadow: inset 0 1px 0 0 rgba(255,255,255,0.05), 0 12px 40px rgba(0,0,0,0.3);
    opacity: 0; visibility: hidden; transform: translateY(8px) scale(0.96);
    transition: opacity 0.25s ease, visibility 0.25s ease, transform 0.25s cubic-bezier(0.16,1,0.3,1);
    z-index: 1;
  }
  .music-player.expanded .music-panel { opacity: 1; visibility: visible; transform: translateY(0) scale(1); }

  .mp-now-playing { padding: 0.875rem; }

  .mp-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 0.75rem; }
  .mp-icon-btn {
    width: 24px; height: 24px; display: flex; align-items: center; justify-content: center;
    border-radius: 6px; background: none; border: none; color: var(--text-dim);
    cursor: pointer; transition: color 0.2s, background 0.2s; flex-shrink: 0;
  }
  .mp-icon-btn:hover { color: var(--text-primary); background: rgba(255,255,255,0.05); }

  .mp-visualizer { display: flex; align-items: flex-end; justify-content: center; gap: 3px; height: 32px; margin-bottom: 0.75rem; }
  .mp-vis-bar { flex: 1; background: var(--accent); border-radius: 2px; height: 4px; opacity: 0.4; transition: height 0.15s ease; }
  .music-player.playing .mp-vis-bar { opacity: 0.7; }

  .mp-controls { display: flex; align-items: center; justify-content: center; gap: 0.25rem; }
  .mp-ctrl {
    width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;
    border-radius: 8px; background: none; border: none; color: var(--text-muted);
    cursor: pointer; transition: color 0.2s, background 0.2s, transform 0.15s;
    font-family: 'JetBrains Mono', monospace;
