---
const items = [
  {
    label: 'Building',
    value: 'Portfolio v1.5',
    icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>',
  },
  {
    label: 'Learning',
    value: 'Figma & UI/UX',
    icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
  },
  {
    label: 'Location',
    value: 'Faisalabad, PK',
    icon: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>',
  },
];
---

<div class="currently-card glass p-4 mt-3" data-animate="fade-up" data-currently data-draggable-currently>
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-2">
      <span class="relative flex h-1.5 w-1.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-success opacity-75"></span>
        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-accent-success"></span>
      </span>
      <span class="font-mono text-[0.6rem] font-medium text-text-dim tracking-wider uppercase">Currently</span>
    </div>
    <span class="font-mono text-[0.55rem] text-text-dim" id="local-time">--:-- PKT</span>
  </div>

  <div class="currently-items">
    {items.map((item, i) => (
      <div class="currently-item" data-currently-item>
        <span class="currently-icon" set:html={item.icon} />
        <span class="currently-label">{item.label}</span>
        <span class="currently-value">{item.value}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .currently-items {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .currently-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.4rem 0.5rem;
    border-radius: 0.375rem;
    transition: background 0.25s ease, transform 0.25s ease;
    cursor: default;
  }
  .currently-item:hover {
    background: var(--glass-hover, rgba(255,255,255,0.05));
    transform: translateX(4px);
  }
  .currently-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: var(--text-dim);
    transition: color 0.25s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .currently-item:hover .currently-icon { color: var(--accent); }
  .currently-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    min-width: 4.5rem;
    flex-shrink: 0;
  }
  .currently-value {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.7rem;
    color: var(--text-secondary);
    transition: color 0.25s ease;
  }
  .currently-item:hover .currently-value { color: var(--text-primary); }

  [data-draggable-currently] {
    cursor: grab;
    touch-action: none;
  }
  [data-draggable-currently]:active { cursor: grabbing; }
  [data-draggable-currently].dragging { cursor: grabbing; }
</style>

<script>
  function updateTime() {
    const el = document.getElementById('local-time');
    if (!el) return;
    const now = new Date().toLocaleTimeString('en-US', {
      timeZone: 'Asia/Karachi',
      hour: '2-digit',
      minute: '2-digit',
      hour12: true,
    });
    el.textContent = now + ' PKT';
  }
  updateTime();
  setInterval(updateTime, 30000);
</script>