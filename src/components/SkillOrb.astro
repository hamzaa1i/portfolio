---
interface Props {
  name: string;
  icon?: string;
  category: 'Build' | 'Animate' | 'Backend' | 'Design' | 'Tools';
  learning?: boolean;
  floatClass?: string;
}

const { name, icon = '⚡', category, learning = false, floatClass = 'animate-float' } = Astro.props;
---

<div
  class:list={[
    'skill-orb glass px-4 py-2.5 inline-flex items-center gap-2.5 select-none',
    floatClass,
  ]}
  data-category={category}
>
  <span class="text-base flex-shrink-0" aria-hidden="true" set:html={icon}></span>
  <div class="flex items-center gap-1.5 min-w-0">
    <span class="text-xs font-mono font-medium text-text-primary truncate leading-tight whitespace-nowrap">
      {name}
    </span>
    {learning && (
      <span class="text-[0.5rem] font-mono text-accent-primary tracking-wider uppercase flex-shrink-0 opacity-70">
        learning
      </span>
    )}
  </div>
</div>