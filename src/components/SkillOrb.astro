---
// SkillOrb.astro — Floating glass skill card with proximity tilt
// CSS float animation + GSAP proximity tilt via .skill-orb class

interface Props {
  name: string;
  icon?: string;
  category: 'Build' | 'Animate' | 'Backend' | 'Design' | 'Tools';
  learning?: boolean;
  animationClass?: string;
}

const {
  name,
  icon = '⚡',
  category,
  learning = false,
  animationClass = 'animate-float',
} = Astro.props;

const categoryColors: Record<string, string> = {
  Build: 'text-accent-cyan border-accent-cyan/20 bg-accent-cyan/5',
  Animate: 'text-accent-purple border-accent-purple/20 bg-accent-purple/5',
  Backend: 'text-accent-blue border-accent-blue/20 bg-accent-blue/5',
  Design: 'text-pink-400 border-pink-400/20 bg-pink-400/5',
  Tools: 'text-amber-400 border-amber-400/20 bg-amber-400/5',
};

const colorClass = categoryColors[category] || categoryColors['Build'];
---

<div
  class:list={[
    'skill-orb glass group relative',
    'px-4 py-3 sm:px-5 sm:py-3.5',
    'flex items-center gap-3',
    'select-none',
    animationClass,
  ]}
  style="perspective: 800px; transform-style: preserve-3d;"
>
  <!-- Icon -->
  <span
    class="text-xl sm:text-2xl flex-shrink-0 transition-transform duration-300 group-hover:scale-110"
    aria-hidden="true"
  >
    {icon}
  </span>

  <!-- Text -->
  <div class="flex flex-col min-w-0">
    <span class="font-heading text-sm sm:text-[0.9375rem] font-medium text-text-primary truncate leading-tight">
      {name}
      {learning && (
        <span class="ml-1.5 text-[0.6rem] font-mono text-text-muted tracking-wider uppercase align-middle">
          learning
        </span>
      )}
    </span>
    <span
      class:list={[
        'text-[0.625rem] font-mono tracking-widest uppercase mt-0.5 leading-none',
        colorClass.split(' ')[0],
      ]}
    >
      {category}
    </span>
  </div>

  <!-- Subtle glow on hover -->
  <div
    class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
    style={`background: radial-gradient(ellipse at center, ${
      category === 'Build' ? 'rgba(0,240,255,0.04)' :
      category === 'Animate' ? 'rgba(191,0,255,0.04)' :
      category === 'Backend' ? 'rgba(59,130,246,0.04)' :
      category === 'Design' ? 'rgba(244,114,182,0.04)' :
      'rgba(251,191,36,0.04)'
    } 0%, transparent 70%);`}
    aria-hidden="true"
  ></div>
</div>