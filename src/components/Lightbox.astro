---
// Lightbox.astro
// The lightbox overlay is already rendered in Layout.astro
// Behavior: animations.js Module 19 (initLightbox)
// Styles: global.css (.lightbox-overlay, .lightbox-image, .lightbox-close)
//
// This component exists as a standalone alternative.
// Currently Layout.astro handles rendering.
---

<div class="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Image viewer">
  <button class="lightbox-close" aria-label="Close image viewer">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </svg>
  </button>
  <img class="lightbox-image" src="" alt="Project screenshot" loading="lazy" />
</div>