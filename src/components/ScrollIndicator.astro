---
// ScrollIndicator.astro — Animated bounce chevron at bottom of hero
// Fades out on scroll via animations.js Module 20 (initScrollIndicator)
---

<div
  data-scroll-indicator
  class="flex flex-col items-center gap-2 select-none"
  aria-hidden="true"
>
  <span class="font-mono text-[0.625rem] tracking-[0.2em] uppercase text-text-muted">
    Scroll
  </span>

  <div class="scroll-indicator flex flex-col items-center gap-0.5">
    <!-- Animated line -->
    <div class="w-px h-8 relative overflow-hidden">
      <div
        class="w-full h-full bg-gradient-to-b from-transparent via-accent-cyan/50 to-accent-cyan"
        style="animation: scrollLine 2s ease-in-out infinite;"
      ></div>
    </div>

    <!-- Chevron -->
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-accent-cyan/60"
    >
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </div>
</div>

<style>
  @keyframes scrollLine {
    0% {
      transform: translateY(-100%);
      opacity: 0;
    }
    30% {
      opacity: 1;
    }
    100% {
      transform: translateY(100%);
      opacity: 0;
    }
  }
</style>