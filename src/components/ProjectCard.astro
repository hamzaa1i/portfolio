---
// ProjectCard.astro — Glass card for Selected Works section
// Shows project thumbnail, title, description, tech tags, action buttons

interface Props {
  title: string;
  description: string;
  type: string;
  role: string;
  stack: string[];
  liveUrl?: string;
  githubUrl?: string;
  placeholderClass?: string;
  index?: number;
}

const {
  title,
  description,
  type,
  role,
  stack,
  liveUrl,
  githubUrl,
  placeholderClass = 'project-placeholder-1',
  index = 0,
} = Astro.props;

const hasLiveUrl = !!liveUrl;
const hasGithub = !!githubUrl;
---

<article
  class="project-card glass glow-hover flex flex-col w-[clamp(320px,80vw,520px)] lg:w-[480px] flex-shrink-0"
  data-cursor="view"
  data-animate="fade-up"
>
  <!-- Project Image / Placeholder -->
  <div class="project-image-hover relative group">
    <div class={`project-placeholder ${placeholderClass}`}>
      <!-- Decorative grid overlay + centered label -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-center">
          <span class="font-mono text-xs text-text-muted tracking-widest uppercase opacity-60">
            {type}
          </span>
          <div class="mt-2 w-10 h-px bg-gradient-to-r from-transparent via-accent-cyan/30 to-transparent mx-auto"></div>
        </div>
      </div>

      <!-- Hover overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-void/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-[0.75rem] flex items-end justify-center pb-4">
        <span class="font-mono text-xs text-accent-cyan tracking-wider uppercase">
          {hasLiveUrl ? 'View Project' : 'Details Below'}
        </span>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5 sm:p-6 pt-4">
    <!-- Type + Role row -->
    <div class="flex items-center gap-2 mb-2">
      <span class="font-mono text-[0.65rem] tracking-wider uppercase text-accent-cyan/80">
        {type}
      </span>
      <span class="w-1 h-1 rounded-full bg-text-muted/40"></span>
      <span class="font-mono text-[0.65rem] tracking-wider uppercase text-text-muted">
        {role}
      </span>
    </div>

    <!-- Title -->
    <h3 class="font-heading text-lg sm:text-xl font-semibold text-text-primary mb-2 leading-tight">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-sm text-text-secondary leading-relaxed mb-4 flex-1">
      {description}
    </p>

    <!-- Tech Tags -->
    <div class="flex flex-wrap gap-1.5 mb-5">
      {stack.map((tech) => (
        <span class="tech-tag">{tech}</span>
      ))}
    </div>

    <!-- Action Buttons -->
    <div class="flex items-center gap-3 mt-auto">
      {/* Live Demo Button */}
      {hasLiveUrl ? (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="glow-btn glow-btn-sm glow-btn-accent flex-1 justify-center"
          data-magnetic
          data-magnetic-strength="0.2"
          data-magnetic-distance="50"
        >
          <span data-magnetic-inner-target class="flex items-center gap-1.5">
            <span>Live Demo</span>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7" />
              <path d="M7 7h10v10" />
            </svg>
          </span>
        </a>
      ) : (
        <div class="tooltip-wrapper flex-1">
          <span class="glow-btn glow-btn-sm glow-btn-disabled flex-1 justify-center inline-flex">
            <span class="flex items-center gap-1.5">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0110 0v4" />
              </svg>
              <span>Private</span>
            </span>
          </span>
          <span class="tooltip">Internal system — not publicly accessible</span>
        </div>
      )}

      {/* Source Code Button */}
      {hasGithub ? (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="glow-btn glow-btn-sm flex-1 justify-center"
          data-magnetic
          data-magnetic-strength="0.2"
          data-magnetic-distance="50"
        >
          <span data-magnetic-inner-target class="flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6" />
              <polyline points="8 6 2 12 8 18" />
            </svg>
            <span>Source</span>
          </span>
        </a>
      ) : (
        <div class="tooltip-wrapper flex-1">
          <span class="glow-btn glow-btn-sm glow-btn-disabled flex-1 justify-center inline-flex">
            <span class="flex items-center gap-1.5">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                <path d="M7 11V7a5 5 0 0110 0v4" />
              </svg>
              <span>Private</span>
            </span>
          </span>
          <span class="tooltip">Private repository</span>
        </div>
      )}
    </div>
  </div>
</article>