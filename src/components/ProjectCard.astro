---
interface Props {
  title: string;
  description: string;
  type: string;
  role: string;
  stack: string[];
  liveUrl?: string;
  githubUrl?: string;
  caseStudyUrl?: string;
  placeholderClass?: string;
}

const { title, description, type, role, stack, liveUrl, githubUrl, caseStudyUrl, placeholderClass = 'project-placeholder-1' } = Astro.props;
const hasLive = !!liveUrl;
const hasGithub = !!githubUrl;
const hasCaseStudy = !!caseStudyUrl;
---

<article class="project-card glass flex flex-col" data-animate="fade-up">
  <!-- Image area with case study overlay -->
  <div class="project-image-hover relative">
    <div class={`project-placeholder ${placeholderClass}`}>
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="font-mono text-[0.6rem] text-text-dim tracking-[0.15em] uppercase">{type}</span>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5 sm:p-6 pt-4">
    <div class="flex items-center gap-2 mb-2">
      <span class="font-mono text-[0.6rem] tracking-wider uppercase text-accent-primary/70">{type}</span>
      <span class="w-1 h-1 rounded-full bg-text-dim"></span>
      <span class="font-mono text-[0.6rem] tracking-wider uppercase text-text-dim">{role}</span>
    </div>

    <h3 class="font-heading text-base sm:text-lg font-semibold text-text-primary mb-2 leading-tight">{title}</h3>
    <p class="text-sm text-text-secondary leading-relaxed mb-4 flex-1">{description}</p>

    <div class="flex flex-wrap gap-1.5 mb-5">
      {stack.map((tech) => <span class="tech-tag">{tech}</span>)}
    </div>

    <div class="flex items-center gap-3 mt-auto">
      {hasCaseStudy && (
        <a href={caseStudyUrl} class="btn-primary btn-sm flex-1 justify-center">
          <span>Case Study</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      )}

      {hasLive && (
        <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary btn-sm flex-1 justify-center">
          <span>Live Site</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      )}

      {hasGithub && (
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary btn-sm flex-1 justify-center">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          <span>Source</span>
        </a>
      )}

      {!hasLive && !hasGithub && !hasCaseStudy && (
        <div class="tooltip-wrapper flex-1">
          <span class="btn-secondary btn-sm btn-disabled flex-1 justify-center inline-flex">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            <span>Private</span>
          </span>
          <span class="tooltip">Internal system, not publicly accessible</span>
        </div>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    position: relative;
    transition: transform 0.4s var(--ease-out-quart), box-shadow 0.4s var(--ease-out-quart);
  }

  .project-card:hover {
    transform: translateY(-4px) !important;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.18), 0 6px 16px rgba(0, 0, 0, 0.12) !important;
    border-color: rgba(255, 255, 255, 0.12) !important;
  }

  .project-card .flex.items-center.gap-3.mt-auto {
    flex-wrap: wrap;
  }
</style>