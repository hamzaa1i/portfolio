---
// Preloader.astro — Brand-consistent ~/hamza entry sequence
// Colored typing: ~ (accent) / (dim) hamza (primary)
// Thin line caret instead of block
---

<div id="preloader" aria-hidden="true">
  <div class="pl-inner">
    <div class="pl-logo">
      <span id="pl-text"></span><span class="pl-caret"></span>
    </div>
    <div class="pl-track" id="pl-track">
      <div class="pl-fill" id="pl-fill"></div>
    </div>
    <div class="pl-meta" id="pl-meta">
      <span id="pl-pct">0</span><span class="pl-dim">%</span>
    </div>
  </div>
</div>

<noscript><style>#preloader{display:none!important}</style></noscript>

<style>
  #preloader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--void, #09090B);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #preloader.pl-exit {
    animation: plOut 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes plOut {
    to {
      opacity: 0;
      transform: translateY(-30px);
    }
  }

  .pl-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .pl-logo {
    display: flex;
    align-items: center;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    min-height: 1.3em;
  }

  /* Thin line caret */
  .pl-caret {
    display: inline-block;
    width: 2px;
    height: 0.85em;
    background: var(--accent, #C8A24E);
    margin-left: 2px;
    border-radius: 1px;
    vertical-align: baseline;
    animation: plBlink 1s step-end infinite;
  }
  @keyframes plBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .pl-track {
    width: min(260px, 55vw);
    height: 2px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    overflow: hidden;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .pl-fill {
    height: 100%;
    width: 0%;
    background: var(--accent, #C8A24E);
    border-radius: 2px;
    box-shadow: 0 0 10px rgba(200, 162, 78, 0.25);
  }

  .pl-meta {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.7rem;
    color: var(--text-dim, #3F3F46);
    letter-spacing: 0.12em;
    font-variant-numeric: tabular-nums;
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .pl-dim {
    opacity: 0.5;
  }
</style>

<script is:inline>
(function () {
  var el = document.getElementById('preloader');
  if (!el) return;

  var KEY = 'portfolio-visited';
  var isReturn = false;
  try { isReturn = sessionStorage.getItem(KEY) === '1'; } catch (e) {}
  var noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  window.__preloaderDone = false;

  function finish() {
    if (window.__preloaderDone) return;
    window.__preloaderDone = true;

    try { sessionStorage.setItem(KEY, '1'); } catch (e) {}
    document.documentElement.style.overflow = '';
    document.removeEventListener('click', skip);
    document.removeEventListener('keydown', skip);

    if (isReturn || noMotion) {
      el.style.display = 'none';
      document.dispatchEvent(new CustomEvent('preloader:complete'));
      return;
    }

    el.classList.add('pl-exit');
    document.dispatchEvent(new CustomEvent('preloader:complete'));
    el.addEventListener('animationend', function () { el.remove(); }, { once: true });
    setTimeout(function () { try { el.remove(); } catch (e) {} }, 1200);
  }

  if (isReturn || noMotion) {
    finish();
    return;
  }

  document.documentElement.style.overflow = 'hidden';

  function skip() { finish(); }
  document.addEventListener('click', skip);
  document.addEventListener('keydown', skip);

  var textEl  = document.getElementById('pl-text');
  var trackEl = document.getElementById('pl-track');
  var fillEl  = document.getElementById('pl-fill');
  var metaEl  = document.getElementById('pl-meta');
  var pctEl   = document.getElementById('pl-pct');

  if (!textEl || !fillEl || !pctEl) { finish(); return; }

  /* ── Brand colors per character ── */
  var s = getComputedStyle(document.documentElement);
  var accentColor  = s.getPropertyValue('--accent').trim() || '#C8A24E';
  var dimColor     = s.getPropertyValue('--text-dim').trim() || '#3F3F46';
  var primaryColor = s.getPropertyValue('--text-primary').trim() || '#FAFAFA';

  var chars = [
    { ch: '~', color: accentColor },
    { ch: '/', color: dimColor },
    { ch: 'h', color: primaryColor },
    { ch: 'a', color: primaryColor },
    { ch: 'm', color: primaryColor },
    { ch: 'z', color: primaryColor },
    { ch: 'a', color: primaryColor },
  ];

  var ci   = 0;
  var prog = 0;

  function typeNext() {
    if (window.__preloaderDone) return;
    if (ci < chars.length) {
      var span = document.createElement('span');
      span.textContent = chars[ci].ch;
      span.style.color = chars[ci].color;
      if (ci === 0) span.style.fontWeight = '700';
      else if (ci === 1) { span.style.fontWeight = '400'; span.style.opacity = '0.5'; }
      else span.style.fontWeight = '700';
      textEl.appendChild(span);
      ci++;
      setTimeout(typeNext, 70 + Math.random() * 50);
    } else {
      if (trackEl) trackEl.style.opacity = '1';
      if (metaEl) metaEl.style.opacity = '1';
      setTimeout(tick, 200);
    }
  }

  function tick() {
    if (window.__preloaderDone) return;

    var inc = prog < 30 ? 3 + Math.random() * 5
            : prog < 70 ? 2 + Math.random() * 3
            : prog < 90 ? 1 + Math.random() * 2
            : 0.5 + Math.random();

    prog = Math.min(100, prog + inc);
    fillEl.style.width = prog + '%';
    pctEl.textContent = Math.round(prog);

    if (prog < 100) {
      setTimeout(tick, 18 + Math.random() * 18);
    } else {
      setTimeout(finish, 300);
    }
  }

  setTimeout(typeNext, 200);
})();
</script>