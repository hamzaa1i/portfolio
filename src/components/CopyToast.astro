<div id="copy-toast" class="copy-toast">
  <span id="copy-toast-icon"></span>
  <span id="copy-toast-text">Copied!</span>
</div>

<style is:global>
  .copy-toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    z-index: 9998;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: var(--elevated, #1F1F23);
    border: 1px solid var(--glass-border, rgba(255,255,255,0.06));
    border-radius: 999px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.16,1,0.3,1), visibility 0.3s ease;
    pointer-events: none;
  }
  .copy-toast.visible {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  #copy-toast-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }
  #copy-toast-icon svg {
    width: 14px;
    height: 14px;
  }
</style>

<script is:inline>
(function() {
  var toast = document.getElementById('copy-toast');
  var toastText = document.getElementById('copy-toast-text');
  var toastIcon = document.getElementById('copy-toast-icon');
  if (!toast) return;

  var timer = null;

  var icons = {
    copy: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>',
    music: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>',
    info: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',
  };

  function showToast(text, type) {
    if (toastText) toastText.textContent = text || 'Done';
    if (toastIcon) toastIcon.innerHTML = icons[type || 'info'] || icons.info;
    clearTimeout(timer);
    toast.classList.add('visible');
    timer = setTimeout(function() {
      toast.classList.remove('visible');
    }, 2500);
  }

  window.__showToast = showToast;

  document.querySelectorAll('a[href^="mailto:"]').forEach(function(link) {
    var clickCount = 0;
    var clickTimer = null;

    link.addEventListener('click', function(e) {
      e.preventDefault();
      clickCount++;

      if (clickCount === 1) {
        clickTimer = setTimeout(function() {
          var email = link.getAttribute('href').replace('mailto:', '');
          if (navigator.clipboard) {
            navigator.clipboard.writeText(email).then(function() {
              showToast('Email copied — double-click to open mail app', 'copy');
            });
          }
          clickCount = 0;
        }, 300);
      } else if (clickCount === 2) {
        clearTimeout(clickTimer);
        clickCount = 0;
        window.location.href = link.getAttribute('href');
      }
    });
  });
})();
</script>