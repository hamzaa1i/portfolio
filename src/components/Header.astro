---
import ThemeSwitcher from './ThemeSwitcher.astro';

const navItems = [
  { label: 'about', href: '#story' },
  { label: 'skills', href: '#skills' },
  { label: 'work', href: '#work' },
  { label: 'contact', href: '#contact' },
];
---

<header
  data-header
  class="floating-header"
>
  <div class="flex items-center justify-between h-full px-5">
    <!-- Logo — ~ opens terminal -->
    <div class="relative z-10 select-none flex items-center">
      <button
        data-terminal-trigger
        class="terminal-trigger font-mono text-[0.8rem] font-semibold text-accent-primary hover:text-accent-hover transition-colors duration-300"
        aria-label="Open terminal"
        title="Open terminal"
      >~</button><a href="#hero" data-nav-link class="font-mono text-[0.8rem] font-semibold tracking-tight text-text-muted hover:text-text-primary transition-colors duration-300">/<span class="text-text-primary">hamza</span></a>
    </div>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-5" aria-label="Main navigation">
      {navItems.map((item) => (
        <a href={item.href} data-nav-link class="code-nav">{item.label}</a>
      ))}

      <div class="w-px h-3.5 bg-white/8 mx-0.5"></div>

      <ThemeSwitcher />

      <a
        href="https://wa.me/923329555786"
        target="_blank"
        rel="noopener noreferrer"
        data-magnetic
        data-magnetic-strength="0.25"
        data-magnetic-radius="60"
        class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full font-mono text-[0.7rem] font-medium text-void bg-accent-primary hover:bg-accent-hover transition-colors duration-200"
      >
        <span>contact me</span>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7" /><path d="M7 7h10v10" />
        </svg>
      </a>
    </nav>

    <!-- Mobile Hamburger -->
    <button data-menu-toggle class="lg:hidden relative z-[100] w-9 h-9 flex items-center justify-center" aria-label="Toggle menu" aria-expanded="false">
      <div class="hamburger-lines">
        <span class="hamburger-line line-1"></span>
        <span class="hamburger-line line-2"></span>
        <span class="hamburger-line line-3"></span>
      </div>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" data-mobile-menu class="mobile-menu-overlay" aria-hidden="true">
    <nav class="relative z-10 flex flex-col items-center justify-center h-full gap-6">
      {navItems.map((item, i) => (
        <a href={item.href} data-nav-link class="mobile-nav-link" style={`--delay: ${i * 0.08}s`}>
          <span class="font-mono text-xs text-text-dim mr-3">0{i + 1}</span>
          <span class="font-mono text-2xl sm:text-3xl font-semibold text-text-primary">
            <span class="text-accent-primary">.</span>{item.label}<span class="text-text-dim">()</span>
          </span>
        </a>
      ))}
      <div class="mt-6 mobile-nav-link" style="--delay: 0.32s">
        <a href="https://wa.me/923329555786" target="_blank" rel="noopener noreferrer" class="btn-primary">
          <span>contact me</span>
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  .terminal-trigger {
    background: none;
    border: none;
    padding: 0.25rem 0;
    margin: 0;
    line-height: 1;
    position: relative;
  }
  .terminal-trigger::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
    opacity: 0.5;
  }
  .terminal-trigger:hover::after {
    transform: scaleX(1);
  }

  .hamburger-lines {
    width: 18px;
    height: 12px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .hamburger-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--text-primary);
    border-radius: 1px;
    transition: transform 0.4s var(--ease-out-expo), opacity 0.3s ease, width 0.3s var(--ease-out-expo);
    transform-origin: center;
  }
  .line-2 { width: 60%; margin-left: auto; }

  [data-menu-toggle].open .line-1 { transform: translateY(5px) rotate(45deg); }
  [data-menu-toggle].open .line-2 { opacity: 0; width: 0; }
  [data-menu-toggle].open .line-3 { transform: translateY(-5px) rotate(-45deg); }

  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    background: rgba(9, 9, 11, 0.97);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s var(--ease-out-expo), visibility 0.5s;
  }
  .mobile-menu-overlay.open { opacity: 1; visibility: visible; }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
    transition-delay: var(--delay, 0s);
  }
  .mobile-menu-overlay.open .mobile-nav-link {
    opacity: 1;
    transform: translateY(0);
  }
  .mobile-nav-link:hover span.font-mono:last-child {
    color: var(--accent) !important;
  }
</style>

<script is:inline>
  (function() {
    var trigger = document.querySelector('[data-terminal-trigger]');
    if (!trigger) return;
    trigger.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      document.dispatchEvent(new CustomEvent('terminal:toggle'));
    });
  })();
</script>