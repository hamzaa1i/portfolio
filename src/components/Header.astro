---
import ThemeSwitcher from './ThemeSwitcher.astro';

const navItems = [
  { label: 'about', href: '/#story' },
  { label: 'skills', href: '/#skills' },
  { label: 'work', href: '/#work' },
  { label: 'contact', href: '/#contact' },
];
---

<header data-header class="floating-header">
  <div class="header-inner">
    <!-- Logo -->
    <div class="header-logo" data-logo-area>
      <button
        data-terminal-trigger
        class="terminal-trigger"
        aria-label="Open terminal"
        title="Open terminal"
      >~</button><a href="/" class="logo-text" data-logo-home>/<span class="logo-name">hamza</span></a>
    </div>

    <!-- Desktop Nav -->
    <nav class="header-nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <a href={item.href} data-nav-link class="code-nav">{item.label}</a>
      ))}
      <a href="/writing" class="code-nav">writing</a>
    </nav>

    <!-- Desktop Controls -->
    <div class="header-controls">
      <!-- Sound Toggle -->
      <button
        data-sound-toggle
        class="header-icon-btn"
        aria-label="Toggle sound"
        title="Toggle sound"
      >
        <svg data-sound-on width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
        </svg>
        <svg data-sound-off width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
        </svg>
      </button>

      <ThemeSwitcher />

      <!-- CTA -->
      <a
        href="https://wa.me/923329555786"
        target="_blank"
        rel="noopener noreferrer"
        data-magnetic
        data-magnetic-strength="0.25"
        data-magnetic-radius="60"
        class="header-cta"
      >
        <span>contact me</span>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7"/><path d="M7 7h10v10"/>
        </svg>
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button data-menu-toggle class="header-hamburger" aria-label="Toggle menu" aria-expanded="false">
      <div class="hamburger-lines">
        <span class="hamburger-line line-1"></span>
        <span class="hamburger-line line-2"></span>
        <span class="hamburger-line line-3"></span>
      </div>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" data-mobile-menu class="mobile-menu-overlay" aria-hidden="true">
    <nav class="mobile-menu-nav">
      {navItems.map((item, i) => (
        <a href={item.href} data-nav-link class="mobile-nav-link" style={`--delay: ${i * 0.08}s`}>
          <span class="mobile-nav-num">0{i + 1}</span>
          <span class="mobile-nav-text">
            <span class="text-accent-primary">.</span>{item.label}<span class="text-text-dim">()</span>
          </span>
        </a>
      ))}
      <a href="/writing" class="mobile-nav-link" style="--delay: 0.32s">
        <span class="mobile-nav-num">05</span>
        <span class="mobile-nav-text">
          <span class="text-accent-primary">.</span>writing<span class="text-text-dim">()</span>
        </span>
      </a>
      <div class="mobile-nav-link" style="--delay: 0.4s">
        <div class="mobile-nav-actions">
          <a href="/resume.pdf" download="Hamza_Ali_Resume.pdf" class="btn-secondary btn-sm">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            <span>resume</span>
          </a>
          <a href="https://wa.me/923329555786" target="_blank" rel="noopener noreferrer" class="btn-primary btn-sm">
            <span>contact me</span>
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7"/><path d="M7 7h10v10"/>
            </svg>
          </a>
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  /* ── Inner layout ── */
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 1.5rem;
  }

  /* ── Logo ── */
  .header-logo {
    position: relative;
    z-index: 100;
    display: flex;
    align-items: center;
    flex-shrink: 0;
    user-select: none;
  }
  .terminal-trigger {
    background: none;
    border: none;
    padding: 0.25rem 0;
    margin: 0;
    line-height: 1;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    cursor: pointer;
    transition: color 0.3s ease;
    position: relative;
  }
  .terminal-trigger::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
    opacity: 0.5;
  }
  .terminal-trigger:hover { color: var(--accent-hover); }
  .terminal-trigger:hover::after { transform: scaleX(1); }

  .logo-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-muted);
    transition: color 0.3s ease;
  }
  .logo-text:hover { color: var(--text-primary); }
  .logo-name { color: var(--text-primary); }

  /* ── Desktop Nav ── */
  .header-nav {
    display: none;
    align-items: center;
    gap: 1.25rem;
  }
  @media (min-width: 1024px) {
    .header-nav { display: flex; }
  }

  .code-nav-page::before { content: ''; }
  .code-nav-page::after { content: ''; }

  /* ── Controls (desktop) ── */
  .header-controls {
    display: none;
    align-items: center;
    gap: 0.5rem;
  }
  @media (min-width: 1024px) {
    .header-controls { display: flex; }
  }

  .header-icon-btn {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: color 0.3s ease;
    background: none;
    border: none;
    padding: 0;
    border-radius: 8px;
    flex-shrink: 0;
  }
  .header-icon-btn:hover {
    color: var(--accent);
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 0.875rem;
    border-radius: 999px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent-contrast);
    background: var(--accent);
    transition: background 0.2s ease;
    flex-shrink: 0;
    margin-left: 0.25rem;
  }
  .header-cta:hover {
    background: var(--accent-hover);
  }

  /* ── Mobile Hamburger ── */
  .header-hamburger {
    display: flex;
    position: relative;
    z-index: 100;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 0;
  }
  @media (min-width: 1024px) {
    .header-hamburger { display: none; }
  }

  .hamburger-lines {
    width: 18px;
    height: 12px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .hamburger-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--text-primary);
    border-radius: 1px;
    transition: transform 0.4s var(--ease-out-expo), opacity 0.3s ease, width 0.3s var(--ease-out-expo);
    transform-origin: center;
  }
  .line-2 { width: 60%; margin-left: auto; }

  [data-menu-toggle].open .line-1 { transform: translateY(5px) rotate(45deg); }
  [data-menu-toggle].open .line-2 { opacity: 0; width: 0; }
  [data-menu-toggle].open .line-3 { transform: translateY(-5px) rotate(-45deg); }

  /* ── Mobile Menu Overlay ── */
  .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    background: var(--void, rgba(9, 9, 11, 0.97));
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s var(--ease-out-expo), visibility 0.5s;
  }
  .mobile-menu-overlay.open { opacity: 1; visibility: visible; }

.mobile-menu-nav {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  gap: 1rem;
  padding: 4rem 2rem 2rem;
  overflow-y: auto;
}

  .mobile-nav-link {
    display: flex;
    align-items: center;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
    transition-delay: var(--delay, 0s);
  }
  .mobile-menu-overlay.open .mobile-nav-link {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-nav-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-right: 0.75rem;
    min-width: 1.5rem;
  }
  .mobile-nav-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(1.5rem, 5vw, 2rem);
    font-weight: 600;
    color: var(--text-primary);
    transition: color 0.3s ease;
  }
  .mobile-nav-link:hover .mobile-nav-text,
  .mobile-nav-link:active .mobile-nav-text {
    color: var(--accent);
  }

  .mobile-nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
</style>

<script is:inline>
  (function() {
    /* Terminal trigger */
    var trigger = document.querySelector('[data-terminal-trigger]');
    if (trigger) {
      trigger.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        document.dispatchEvent(new CustomEvent('terminal:toggle'));
      });
    }

/* Logo click — scroll to top on homepage, navigate on other pages */
var logoHome = document.querySelector('[data-logo-home]');
if (logoHome) {
  logoHome.addEventListener('click', function(e) {
    if (window.location.pathname === '/') {
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();
      window.scrollTo({ top: 0, behavior: 'smooth' });
      if (window.location.hash) {
        history.replaceState(null, '', '/');
      }
    }
    /* On other pages — do nothing here, let page-fade handle navigation to / */
  }, true);
}

    /* Mobile menu — close on nav link click */
    var mobileLinks = document.querySelectorAll('[data-mobile-menu] a[data-nav-link]');
    mobileLinks.forEach(function(link) {
      link.addEventListener('click', function() {
        var menu = document.querySelector('[data-mobile-menu]');
        var toggle = document.querySelector('[data-menu-toggle]');
        if (menu && menu.classList.contains('open')) {
          menu.classList.remove('open');
          if (toggle) {
            toggle.classList.remove('open');
            toggle.setAttribute('aria-expanded', 'false');
          }
          menu.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }
      });
    });
  })();
</script>