---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  date: string;
  readingTime: string;
  tags?: string[];
  description?: string;
  backUrl?: string;
  backLabel?: string;
}

const {
  title,
  date,
  readingTime,
  tags = [],
  description = '',
  backUrl = '/writing',
  backLabel = 'back to writing',
} = Astro.props;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": date,
  "author": {
    "@type": "Person",
    "name": "Hamza Ali",
    "url": "https://hamzaalidev.vercel.app"
  },
  "publisher": {
    "@type": "Person",
    "name": "Hamza Ali"
  },
  "keywords": tags.join(', ')
});
---

<Layout title={`${title} — Hamza Ali`} description={description}>
  <Header />

  <div class="reading-progress" id="reading-progress"></div>

  <main
    class="min-h-screen px-6"
    style="padding-top: calc(var(--header-height) + var(--header-margin) * 2 + 3rem);"
  >
    <article class="max-w-2xl mx-auto">
      <a
        href={backUrl}
        class="inline-flex items-center gap-1.5 text-text-dim font-mono text-xs hover:text-accent-primary transition-colors mb-8"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        {backLabel}
      </a>

      <header class="mb-10">
        <div class="flex items-center gap-3 font-mono text-xs text-text-dim mb-4">
          <time>{date}</time>
          <span class="text-text-dim/30">·</span>
          <span>{readingTime}</span>
        </div>
        <h1 class="text-heading-1 font-heading font-bold text-text-primary mb-4 leading-tight">{title}</h1>
        {description && (
          <p class="text-body-lg text-text-secondary leading-relaxed">{description}</p>
        )}
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-5">
            {tags.map((tag) => (
              <span class="font-mono text-[0.6rem] tracking-wider uppercase px-2.5 py-1 rounded-full border border-white/[0.06] text-text-muted">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="post-content">
        <slot />
      </div>

      <div class="border-t border-white/[0.06] mt-14 pt-8 pb-4">
        <div class="glass p-5 flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <div class="flex-1">
            <p class="text-sm font-heading font-semibold text-text-primary mb-1">Enjoyed this post?</p>
            <p class="text-xs text-text-secondary">Got a project in mind? I'd love to hear about it.</p>
          </div>
          <a href="/#contact" class="btn-primary btn-sm flex-shrink-0">
            <span>get in touch</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>
      </div>
    </article>
  </main>

  <div class="py-10"></div>
  <Footer />

  <script type="application/ld+json" set:html={articleSchema}></script>

  <script>
    (function() {
      var bar = document.getElementById('reading-progress');
      if (!bar) return;

      function update() {
        var scrollTop = window.scrollY;
        var docHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (docHeight <= 0) return;
        var progress = Math.min((scrollTop / docHeight) * 100, 100);
        bar.style.width = progress + '%';
      }

      window.addEventListener('scroll', update, { passive: true });
      update();
    })();
  </script>
</Layout>

<style is:global>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--accent);
    z-index: 9999;
    transition: width 0.1s linear;
  }

  .post-content h2 {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .post-content h3 {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(1.05rem, 2.5vw, 1.2rem);
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .post-content p {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }
  .post-content strong {
    color: var(--text-primary);
    font-weight: 600;
  }
  .post-content em {
    font-style: italic;
    color: var(--text-secondary);
  }
  .post-content a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .post-content a:hover {
    color: var(--accent-hover);
  }
  .post-content ul, .post-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .post-content li {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }
  .post-content ul li { list-style-type: disc; }
  .post-content ol li { list-style-type: decimal; }
  .post-content ul li::marker { color: var(--accent); }
  .post-content ol li::marker { color: var(--accent); font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; }
  .post-content blockquote {
    border-left: 2px solid var(--accent);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--glass-bg);
    border-radius: 0 0.5rem 0.5rem 0;
  }
  .post-content blockquote p {
    color: var(--text-primary);
    font-style: italic;
    margin-bottom: 0;
  }
  .post-content code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--accent);
  }
  .post-content pre {
    background: rgba(9, 9, 11, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.5rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .post-content pre code {
    background: none;
    padding: 0;
    font-size: 0.8rem;
    color: var(--text-secondary);
  }
  .post-content hr {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin: 2rem 0;
  }
  .post-content img {
    max-width: 100%;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    margin: 1.5rem 0;
  }
</style>