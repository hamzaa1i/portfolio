---
import { activeTheme as t } from '../config/theme';
import { themes } from '../config/theme';
import '../styles/global.css';
import Terminal from '../components/Terminal.astro';
import Preloader from '../components/Preloader.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Hamza Ali — Digital Solutions Architect',
  description = '17-year-old developer who builds production websites, ERP systems, and brand identities for international businesses.',
} = Astro.props;

const siteURL = 'https://hamzaali-dev.vercel.app';

/* Build CSS custom-property string from active theme */
const themeStyle = [
  `background-color:${t.void}`,
  `color:${t.textPrimary}`,
  `color-scheme:${t.isDark ? 'dark' : 'light'}`,
  `--void:${t.void}`,
  `--midnight:${t.midnight}`,
  `--surface:${t.surface}`,
  `--elevated:${t.elevated}`,
  `--glass-bg:${t.glassBg}`,
  `--glass-border:${t.glassBorder}`,
  `--glass-hover:${t.glassHover}`,
  `--glass-hover-border:${t.glassHoverBorder}`,
  `--text-primary:${t.textPrimary}`,
  `--text-secondary:${t.textSecondary}`,
  `--text-muted:${t.textMuted}`,
  `--text-dim:${t.textDim}`,
  `--accent:${t.accent}`,
  `--accent-hover:${t.accentHover}`,
  `--accent-dim:${t.accentDim}`,
  `--accent-glow:${t.accentGlow}`,
  `--accent-subtle:${t.accentSubtle}`,
  `--accent-contrast:${t.accentContrast}`,
  `--accent-success:${t.success}`,
  `--gradient-accent-text:${t.gradientText}`,
].join(';');
---

<!doctype html>
<html lang="en" class={t.isDark ? 'dark' : ''} style={themeStyle}>
  <head>
    <!-- Prevent FOUC -->
    <script is:inline>
      (function(){ document.documentElement.classList.add(document.documentElement.classList.contains('dark') ? 'dark' : 'light'); })();
    </script>

    <!-- ADD THIS NEW SCRIPT RIGHT HERE ↓ -->
    <script is:inline define:vars={{ themesJSON: JSON.stringify(themes) }}>
      (function() {
        try {
          var saved = localStorage.getItem('portfolio-theme');
          if (!saved) return;
          var themes = JSON.parse(themesJSON);
          var th = themes[saved];
          if (!th) return;
          var h = document.documentElement;
          h.style.setProperty('--void', th.void);
          h.style.setProperty('--midnight', th.midnight);
          h.style.setProperty('--surface', th.surface);
          h.style.setProperty('--elevated', th.elevated);
          h.style.setProperty('--glass-bg', th.glassBg);
          h.style.setProperty('--glass-border', th.glassBorder);
          h.style.setProperty('--glass-hover', th.glassHover);
          h.style.setProperty('--glass-hover-border', th.glassHoverBorder);
          h.style.setProperty('--text-primary', th.textPrimary);
          h.style.setProperty('--text-secondary', th.textSecondary);
          h.style.setProperty('--text-muted', th.textMuted);
          h.style.setProperty('--text-dim', th.textDim);
          h.style.setProperty('--accent', th.accent);
          h.style.setProperty('--accent-hover', th.accentHover);
          h.style.setProperty('--accent-dim', th.accentDim);
          h.style.setProperty('--accent-glow', th.accentGlow);
          h.style.setProperty('--accent-subtle', th.accentSubtle);
          h.style.setProperty('--accent-contrast', th.accentContrast);
          h.style.setProperty('--accent-success', th.success);
          h.style.setProperty('--gradient-accent-text', th.gradientText);
          h.style.backgroundColor = th.void;
          h.style.color = th.textPrimary;
          if (th.isDark) { h.classList.add('dark'); h.classList.remove('light'); }
          else { h.classList.remove('dark'); h.classList.add('light'); }
        } catch(e) {}
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Hamza Ali" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content={t.void} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteURL}/og-image.jpg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Hamza Ali",
      "jobTitle": "Digital Solutions Architect",
      "url": siteURL,
      "sameAs": ["https://github.com/hamzaa1i"],
      "knowsAbout": ["Web Development", "ERP Systems", "UI/UX Design", "Brand Identity"],
      "address": { "@type": "PostalAddress", "addressLocality": "Faisalabad", "addressRegion": "Punjab", "addressCountry": "PK" }
    })} />
  </head>

  <body class="bg-void text-text-primary font-body antialiased overflow-x-hidden">
    <Preloader />
    <div class="css-bg-fallback" aria-hidden="true"></div>

    <div class="scroll-progress" aria-hidden="true"><div class="scroll-progress-bar"></div></div>
    <div class="page-blur-overlay" aria-hidden="true"></div>

    <main class="content-layer relative z-content">
      <slot />
    </main>

    <div class="lightbox-overlay" role="dialog" aria-modal="true" aria-label="Image viewer">
      <button class="lightbox-close" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <img class="lightbox-image" src="" alt="Screenshot" loading="lazy" />
    </div>

    <Terminal />

    <button data-scroll-top class="scroll-to-top glass" aria-label="Scroll to top">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
    </button>

    <script>
      import { initAnimations } from '../scripts/animations.js';

      function boot() {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            initAnimations();
          });
        });
      }

      if (window.__preloaderDone) {
        boot();
      } else {
        document.addEventListener('preloader:complete', boot, { once: true });
      }
    </script>

    <script is:inline>
      if ('ontouchstart' in window || navigator.maxTouchPoints > 0) document.documentElement.classList.add('is-touch');
      else document.documentElement.classList.add('is-pointer');
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) document.documentElement.classList.add('reduced-motion');
    </script>
  </body>
</html>