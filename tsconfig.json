{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
      "jsx": "react-jsx",
      "jsxImportSource": "react",
      "baseUrl": ".",
      "paths": {
        "@/*": ["src/*"],
        "@components/*": ["src/components/*"],
        "@layouts/*": ["src/layouts/*"],
        "@styles/*": ["src/styles/*"],
        "@scripts/*": ["src/scripts/*"]
      },
      "strictNullChecks": true,
      "allowJs": true,
      "moduleResolution": "bundler"
    },
    "include": ["src/**/*", "env.d.ts"],
    "exclude": ["node_modules", "dist"]
  }